__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/

# ncs-console dependencies (pulled by ncs-console/setup.ps1)
ncs-console/App/lib/
# ncs-console shortcut icon (generated on first install-shortcut.ps1 run)
ncs-console/App/ncs-icon.ico

# Installed ansible collections are regenerated by `just install-collections`
# from collections/vendor/*.tar.gz (internal.*) and ansible-galaxy (community).
# Ignore everything under ansible_collections/; the committed vendor tarballs
# live one level up (collections/vendor/) and stay tracked.
**/collections/ansible_collections/

# Secrets
.env
.vaultpass

# Claude Code
.claude
.claude/
CLAUDE.md

# Operator-only, never commit
docs/LAB_ACCESS.md
docs/_dev/

# Per-collection test inventory + vault password — see docs/collections/COLLECTION_LAYOUT.md
ncs-ansible-*/tests/inventory/
ncs-ansible-*/tests/.vault_pass
