__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/

# ncs-console dependencies (pulled by ncs-console/setup.ps1)
ncs-console/App/lib/
# ncs-console shortcut icon (generated on first install-shortcut.ps1 run)
ncs-console/App/ncs-icon.ico

# Installed local internal.* collections (resolved by requirements.yml).
# Community collections elsewhere in this dir remain tracked; only the
# locally-installed internal collections are ignored.
# Note: collections/vendor/ (committed tarballs) is NOT in this rule.
**/collections/ansible_collections/internal/

# Secrets
.env
.vaultpass

# Claude Code
.claude/
CLAUDE.md

# Operator-only, never commit
docs/LAB_ACCESS.md
docs/_dev/

# Per-collection test inventory + vault password — see docs/COLLECTION_LAYOUT.md
ncs-ansible-*/tests/inventory/
ncs-ansible-*/tests/.vault_pass
