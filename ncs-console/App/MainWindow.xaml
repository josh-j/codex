<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="NCS Console"
    Height="800"
    Width="900"
    MinHeight="600"
    MinWidth="900"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResize"
    Background="#111217"
    FontFamily="Segoe UI">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#181b1f" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1e2228" />
        <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#242932" />
        <SolidColorBrush x:Key="AccentBrush" Color="#6e9fff" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#182742" />
        <SolidColorBrush x:Key="WarnBrush" Color="#d6a24a" />
        <SolidColorBrush x:Key="WarnSoftBrush" Color="#352a19" />
        <SolidColorBrush x:Key="DangerBrush" Color="#f06478" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#381e24" />
        <SolidColorBrush x:Key="InfoBrush" Color="#78a9ff" />
        <SolidColorBrush x:Key="InfoSoftBrush" Color="#182742" />
        <SolidColorBrush x:Key="BorderBrush" Color="#2c3038" />
        <SolidColorBrush x:Key="TextBrush" Color="#d8dce2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8e939c" />

        <CornerRadius x:Key="RadiusSm">4</CornerRadius>
        <CornerRadius x:Key="RadiusMd">6</CornerRadius>
        <CornerRadius x:Key="RadiusLg">8</CornerRadius>
        <Thickness x:Key="InputMargin">0,3,0,6</Thickness>
        <Thickness x:Key="InputPadding">8,5,8,5</Thickness>
        <Thickness x:Key="CardPadding">12</Thickness>
        <Thickness x:Key="CardMargin">0,0,0,8</Thickness>
        <Thickness x:Key="ContentMargin">8</Thickness>
        <Thickness x:Key="SectionGap">0,6,0,0</Thickness>
        <FontFamily x:Key="FontUI">Segoe UI</FontFamily>
        <FontFamily x:Key="FontMono">Consolas</FontFamily>
        <sys:Double x:Key="FontSizeXs">9</sys:Double>
        <sys:Double x:Key="FontSizeSm">10</sys:Double>
        <sys:Double x:Key="FontSizeMd">11</sys:Double>
        <sys:Double x:Key="FontSizeLg">12</sys:Double>
        <sys:Double x:Key="FontSizeXl">13</sys:Double>
        <sys:Double x:Key="FontSizeTitle">14</sys:Double>

        <Thickness x:Key="MarginGapSm">0,4,0,0</Thickness>
        <Thickness x:Key="MarginGapMd">0,6,0,0</Thickness>
        <Thickness x:Key="MarginGapLg">0,8,0,0</Thickness>
        <Thickness x:Key="MarginStatusItem">10,0,0,0</Thickness>
        <Thickness x:Key="MarginLabelValue">0,0,4,0</Thickness>
        <Thickness x:Key="MarginInlineSm">0,0,4,0</Thickness>
        <Thickness x:Key="MarginInlineMd">8,0,0,0</Thickness>
        <Thickness x:Key="MarginDivider">0,10,0,10</Thickness>
        <Thickness x:Key="MarginSectionTitle">0,0,0,6</Thickness>

        <Thickness x:Key="PaddingXs">4,2,4,2</Thickness>
        <Thickness x:Key="PaddingSm">6,3,6,3</Thickness>
        <Thickness x:Key="PaddingMd">8,4,8,4</Thickness>
        <Thickness x:Key="PaddingLg">10,6,10,6</Thickness>
        <Thickness x:Key="PaddingBadgeSm">6,1,6,1</Thickness>
        <Thickness x:Key="PaddingPill">8,2,8,2</Thickness>
        <Thickness x:Key="PaddingTab">12,4,12,4</Thickness>
        <Thickness x:Key="PaddingBar">12,0,12,0</Thickness>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="{StaticResource InputMargin}" />
            <Setter Property="Padding" Value="{StaticResource InputPadding}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="#d8dce2" />
            <Setter Property="CaretBrush" Value="#d8dce2" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="{StaticResource InputMargin}" />
            <Setter Property="Padding" Value="{StaticResource InputPadding}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="#d8dce2" />
            <Setter Property="CaretBrush" Value="#d8dce2" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="{StaticResource InputMargin}" />
            <Setter Property="Padding" Value="{StaticResource InputPadding}" />
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="#d8dce2" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template" Value="{DynamicResource NcsComboBoxTemplate}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
            <Setter Property="Margin" Value="{StaticResource MarginGapSm}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBorder" Width="14" Height="14" Background="#1e2228" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Path x:Name="CheckMark" Width="8" Height="8" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.5" Data="M1 5 L4 8 L9 2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#3c4654" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinWidth" Value="70" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{StaticResource RadiusLg}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#242932" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#363b44" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2a3040" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3c4654" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>
        <Style x:Key="PrimaryTabButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,8,14,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabContainer" Background="Transparent" CornerRadius="16" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabContainer" Property="Background" Value="#1a2029" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TabContainer" Property="Background" Value="#202938" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="TabContainer" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Active" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabContainer" Property="Background" Value="#223456" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#5d6470" />
                                <Setter TargetName="TabContainer" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#5d6470" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CloseTitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Foreground" Value="#ff8ea0" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#5d6470" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
            <Setter Property="Padding" Value="{StaticResource CardPadding}" />
            <Setter Property="Margin" Value="{StaticResource CardMargin}" />
        </Style>
        <Style x:Key="SectionExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Focusable="False" Cursor="Hand" OverridesDefaultStyle="True">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="0,4">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <DockPanel>
                                    <Path x:Name="ExpanderIcon" DockPanel.Dock="Left" Width="6" Height="6" Stretch="Uniform" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M3 1 L10 8 L3 15" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <ContentPresenter DockPanel.Dock="Left" ContentSource="Header" VerticalAlignment="Center" />
                                    <Border DockPanel.Dock="Right" Height="1" Background="{StaticResource BorderBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                </DockPanel>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite" ContentSource="Content" Visibility="Collapsed" Margin="{StaticResource MarginGapSm}" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                <Setter TargetName="ExpanderIcon" Property="Data" Value="M1 3 L8 10 L15 3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusLg}" SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1a1f27" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1d2834" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeLg}" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="IsExpanded" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusMd}" Padding="{TemplateBinding Padding}" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path x:Name="GlyphIcon" Grid.Column="0" Width="10" Height="10" Stretch="Uniform" Fill="{StaticResource TextMutedBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="20,0,0,0" Visibility="Collapsed" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="GlyphIcon" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="GlyphIcon" Property="Data" Value="M3 1 L10 6 L3 11" />
                                <Setter TargetName="GlyphIcon" Property="Fill" Value="Transparent" />
                                <Setter TargetName="GlyphIcon" Property="Stroke" Value="{StaticResource TextMutedBrush}" />
                                <Setter TargetName="GlyphIcon" Property="StrokeThickness" Value="1.5" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsExpanded" Value="True" />
                                    <Condition Property="HasItems" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="GlyphIcon" Property="Data" Value="M1 3 L6 10 L11 3" />
                            </MultiTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#182742" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1a1f27" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NcsScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="#151820" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NcsScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#3d4654" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="{TemplateBinding Background}" CornerRadius="6" Margin="2" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#58657a" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#78a9ff" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="#151820" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource NcsScrollBarRepeatButtonStyle}" Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource NcsScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource NcsScrollBarRepeatButtonStyle}" Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="12" />
                                <Setter Property="Width" Value="Auto" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ComboItemBorder" Background="{TemplateBinding Background}" CornerRadius="6" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ComboItemBorder" Property="Background" Value="#25303c" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ComboItemBorder" Property="Background" Value="#182742" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComboBoxToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}" BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}" BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="36" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1" Background="#161920" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" CornerRadius="0,8,8,0">
                                    <TextBlock Text="▾" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="NcsComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton Name="ToggleButton" Style="{StaticResource ComboBoxToggleButtonStyle}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False" />
                <ContentPresenter Margin="10,5,40,5" VerticalAlignment="Center" HorizontalAlignment="Left" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                    <Border Background="#171b21" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource PaddingSm}" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                        <ScrollViewer>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
        </ControlTemplate>
        <DataTemplate x:Key="PreflightItemTemplate">
            <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="{StaticResource PaddingSm}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="StatusBadge" Width="40" Height="18" CornerRadius="9" Background="{StaticResource DangerSoftBrush}" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusBadgeText" Text="FAIL" Foreground="{StaticResource DangerBrush}" FontSize="{StaticResource FontSizeXs}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="{StaticResource MarginInlineMd}">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeLg}" Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="{StaticResource FontSizeMd}" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Passed}" Value="True">
                    <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                    <Setter TargetName="StatusBadgeText" Property="Text" Value="PASS" />
                    <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="PathItemTemplate">
            <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource PaddingLg}">
                <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="#0f1117" BorderBrush="#2c3038" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <Border x:Name="TitleBarDragRegion" Grid.Row="0" Background="#0d1015" BorderBrush="#22262d" BorderThickness="0,0,0,1">
                <Grid Margin="14,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="10" Height="10" Background="{StaticResource AccentBrush}" CornerRadius="5" Margin="0,0,8,0" />
                        <TextBlock x:Name="TitleBarTitleText" Text="NCS Console" Foreground="White" FontSize="{StaticResource FontSizeXl}" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <Button x:Name="SettingsToggleButton" Content="⚙ Settings" Style="{StaticResource PrimaryTabButtonStyle}" Tag="Inactive" ToolTip="Toggle settings panel" />
                        <Button x:Name="OperateToggleButton" Content="▶ Playbooks" Style="{StaticResource PrimaryTabButtonStyle}" Tag="Active" ToolTip="Toggle operate panel" />
                        <Button x:Name="ConsoleShowButton" Content="⌨ Console" Style="{StaticResource PrimaryTabButtonStyle}" Tag="Inactive" Margin="0" ToolTip="Toggle console panel" />
                    </StackPanel>
                    <Border Grid.Column="2" Background="Transparent" />
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MinimizeWindowButton" Style="{StaticResource TitleBarButtonStyle}">
                            <Path Width="10" Height="1" Stretch="Fill" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.5" Data="M0 0 L10 0" />
                        </Button>
                        <Button x:Name="MaximizeWindowButton" Style="{StaticResource TitleBarButtonStyle}">
                            <Path Width="10" Height="10" Stretch="Fill" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M0 0 L10 0 L10 10 L0 10 Z" />
                        </Button>
                        <Button x:Name="CloseWindowButton" Style="{StaticResource CloseTitleBarButtonStyle}">
                            <Path Width="10" Height="10" Stretch="Fill" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.5" Data="M0 0 L10 10 M10 0 L0 10" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="OperatePanel" Grid.Row="1" Margin="{StaticResource ContentMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SettingsColumn" Width="0" MinWidth="0" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition x:Name="ConsoleColumn" Width="0" MinWidth="0" />
                </Grid.ColumnDefinitions>

                <ScrollViewer x:Name="SettingsPanel" Grid.Column="0" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <Border Style="{StaticResource StatusCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="{StaticResource MarginSectionTitle}">
                                <TextBlock DockPanel.Dock="Left" Text="Settings" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                <Button x:Name="SettingsCloseButton" DockPanel.Dock="Right" Content="✕" Style="{StaticResource CloseTitleBarButtonStyle}" Width="24" Height="24" MinWidth="0" Padding="0" Margin="8,0,0,0" FontSize="{StaticResource FontSizeSm}" HorizontalAlignment="Right" ToolTip="Close settings" />
                            </DockPanel>
                            <TextBlock Text="SSH Ansible Host" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="SshHostTextBox" />
                            <TextBlock Text="SSH Ansible Host User" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="SshUserTextBox" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Port" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="SshPortTextBox" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Auth" Foreground="{StaticResource TextMutedBrush}" />
                                    <ComboBox x:Name="SshAuthModeComboBox" />
                                </StackPanel>
                            </Grid>
                            <StackPanel x:Name="SshKeyPathPanel">
                                <TextBlock Text="Key Path" Foreground="{StaticResource TextMutedBrush}" />
                                <TextBox x:Name="SshKeyPathTextBox" />
                                <TextBlock Text="Passphrase" Foreground="{StaticResource TextMutedBrush}" />
                                <PasswordBox x:Name="SshKeyPassphraseBox" />
                            </StackPanel>
                            <StackPanel x:Name="SshPasswordPanel">
                                <TextBlock Text="Password" Foreground="{StaticResource TextMutedBrush}" />
                                <PasswordBox x:Name="SshPasswordBox" />
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="{StaticResource MarginDivider}" />
                            <TextBlock Text="Remote Ansible Project Path" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="RemoteRepoPathTextBox" />
                            <Button x:Name="SaveSettingsButton" MinWidth="0" Padding="{StaticResource PaddingSm}" FontSize="{StaticResource FontSizeMd}" Margin="{StaticResource MarginGapLg}" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="10" Height="10" Stretch="Uniform" Stroke="{StaticResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M3 1 L3 15 M1 13 L3 15 L5 13 M13 15 L13 1 M11 3 L13 1 L15 3" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="Save" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <GridSplitter x:Name="SettingsSplitter" Grid.Column="1" Width="4" Background="#2c3038" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="3,0" Visibility="Collapsed" />

                    <Grid x:Name="OperateContent" Grid.Column="2" HorizontalAlignment="Stretch">
                        <Border Style="{StaticResource StatusCardStyle}" Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Margin="{StaticResource MarginSectionTitle}">
                                    <TextBlock DockPanel.Dock="Left" Text="Playbooks" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                </DockPanel>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#12151a" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Margin="0,0,4,0">
                                        <ScrollViewer x:Name="ActionScrollViewer" VerticalScrollBarVisibility="Auto" Padding="4,4,0,4">
                                            <TreeView x:Name="ActionTreeView" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" FontFamily="{StaticResource FontMono}" Padding="0" ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                                        </ScrollViewer>
                                    </Border>
                                    <ScrollViewer x:Name="ActionPropertiesPanel" Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="4,0,0,0" MinWidth="200" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock x:Name="ActionSelectionTitle" Text="Select a playbook" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeLg}" FontWeight="SemiBold" Margin="{StaticResource MarginSectionTitle}" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginSectionTitle}">
                                                <Button x:Name="RunButton" MinWidth="0" Padding="{StaticResource PaddingSm}" FontSize="{StaticResource FontSizeMd}" Margin="0,0,4,0" ToolTip="Run selected action">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Width="8" Height="10" Stretch="Uniform" Fill="White" Data="M0 0 L8 5 L0 10 Z" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                        <TextBlock Text="Run" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="CancelButton" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingSm}" FontSize="{StaticResource FontSizeMd}" Margin="0" ToolTip="Cancel running action" Visibility="Collapsed">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Width="8" Height="8" Stretch="Uniform" Fill="{StaticResource DangerBrush}" Data="M0 0 L8 0 L8 8 L0 8 Z" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                        <TextBlock Text="Stop" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="Limit" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" />
                                            <TextBox x:Name="ActionLimitTextBox" ToolTip="--limit pattern: groups, hosts, wildcards (site*), negation (!host), intersection (:&amp;)" />
                                            <Border x:Name="ActionLimitTreeBorder" Visibility="Collapsed" Background="#12151a" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" MaxHeight="150" Margin="0,0,0,4">
                                                <ScrollViewer x:Name="ActionLimitTreeScroll" VerticalScrollBarVisibility="Auto" Padding="4,4,0,4">
                                                    <TreeView x:Name="ActionLimitTree" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeSm}" Padding="0" ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                                                </ScrollViewer>
                                            </Border>
                                            <TextBlock Text="Tags" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" />
                                            <TextBox x:Name="ActionTagsTextBox" ToolTip="--tags filter (comma-separated)" />
                                            <CheckBox x:Name="ActionCheckModeCheckBox" Content="Check mode (dry run)" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginGapSm}" />
                                            <CheckBox x:Name="ActionDiffCheckBox" Content="Show diff" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" />
                                            <TextBlock Text="Verbosity" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginGapSm}" />
                                            <ComboBox x:Name="ActionVerbosityComboBox" ToolTip="Ansible verbosity level" />
                                            <StackPanel x:Name="ActionOptionsPanel" Margin="{StaticResource MarginGapSm}" Visibility="Collapsed" />
                                            <TextBlock Text="Extra Args" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginGapSm}" />
                                            <TextBox x:Name="ExtraArgsTextBox" TextWrapping="Wrap" AcceptsReturn="True" Height="40" VerticalScrollBarVisibility="Auto" ToolTip="Additional ansible-playbook arguments" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <GridSplitter x:Name="ConsoleSplitter" Grid.Column="3" Width="4" Background="#2c3038" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="3,0" Visibility="Collapsed" />

                    <Grid x:Name="ConsolePane" Grid.Column="4" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8,8,0,0" Padding="{StaticResource PaddingLg}">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Text="Console" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeMd}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="CopyOutputButton" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingSm}" FontSize="{StaticResource FontSizeMd}" ToolTip="Copy output to clipboard">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Width="10" Height="10" Stretch="Uniform" Stroke="{StaticResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M4 0 L12 0 L12 10 L4 10 Z M0 3 L0 13 L8 13 L8 10" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                <TextBlock Text="Copy" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ExportOutputButton" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingSm}" FontSize="{StaticResource FontSizeMd}" ToolTip="Export output to file">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Width="10" Height="10" Stretch="Uniform" Stroke="{StaticResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M5 0 L5 8 M2 5 L5 8 L8 5 M0 10 L10 10" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                <TextBlock Text="Export" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ConsoleToggleButton" Content="✕" Style="{StaticResource CloseTitleBarButtonStyle}" Width="24" Height="24" MinWidth="0" Padding="0" Margin="8,0,0,0" FontSize="{StaticResource FontSizeSm}" ToolTip="Collapse console" />
                                    </StackPanel>
                                </DockPanel>
                                <TextBox x:Name="CommandPreviewTextBox" IsReadOnly="True" TextWrapping="NoWrap" Background="#0d1015" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="{StaticResource MarginGapSm}" Padding="{StaticResource PaddingSm}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeMd}" Foreground="{StaticResource TextBrush}" />
                            </StackPanel>
                        </Border>

                        <TextBox x:Name="ConsoleTextBox" Grid.Row="1" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeLg}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#0d1015" Foreground="#d8dce2" CaretBrush="#d8dce2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1" />

                        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" Padding="{StaticResource PaddingMd}">
                            <Expander IsExpanded="False" Style="{StaticResource SectionExpanderStyle}" Margin="0">
                                <Expander.Header>
                                    <TextBlock Text="Detected Paths" FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                </Expander.Header>
                                <ListBox x:Name="DetectedPathsListBox" Margin="{StaticResource MarginGapSm}" MaxHeight="100" BorderThickness="0" Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}" ItemTemplate="{StaticResource PathItemTemplate}" />
                            </Expander>
                        </Border>
                    </Grid>
                </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="PreflightButton" Grid.Column="0" MinWidth="0" Padding="10,0" VerticalAlignment="Stretch" ToolTip="Connect to remote host" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0,1,1,0" BorderBrush="#22262d">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <Path Width="12" Height="10" Stretch="Uniform" Fill="White" Data="M0 1 L4 5 L0 9 M12 1 L8 5 L12 9" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock x:Name="PreflightButtonText" Text="Connect" VerticalAlignment="Center" FontSize="{StaticResource FontSizeSm}" />
                    </StackPanel>
                </Button>
                <Border Grid.Column="1" Background="#0d1015" BorderBrush="#22262d" BorderThickness="0,1,0,0" Padding="{StaticResource PaddingBar}">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ConnectionInfoText" Grid.Column="0" Text="" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeMd}" VerticalAlignment="Center" />
                    <Border x:Name="RunStateBorder" Grid.Column="1" Visibility="Collapsed" Background="#1e2228" CornerRadius="{StaticResource RadiusSm}" Padding="{StaticResource PaddingBadgeSm}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="RunStateText" Text="Idle" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeXs}" FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock x:Name="RunMetaText" Margin="{StaticResource MarginInlineSm}" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeXs}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="StatusTextBlock" Grid.Column="2" Text="Ready." TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeMd}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="{StaticResource MarginStatusItem}" />
                    <StackPanel x:Name="ExitCodePanel" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MarginStatusItem}" Visibility="Collapsed">
                        <TextBlock Text="Exit:" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginLabelValue}" />
                        <TextBlock x:Name="ExitCodeTextBlock" Text="-" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel x:Name="DurationPanel" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MarginStatusItem}" Visibility="Collapsed">
                        <TextBlock Text="Duration:" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginLabelValue}" />
                        <TextBlock x:Name="DurationTextBlock" Text="-" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
