<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="NCS Console"
    Height="800"
    Width="900"
    MinHeight="600"
    MinWidth="900"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResize"
    Background="#111217"
    FontFamily="Segoe UI">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <!-- @@MAIN_WINDOW_RESOURCES@@ -->

    <Border Background="#0f1117" BorderBrush="#2c3038" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <Border x:Name="TitleBarDragRegion" Grid.Row="0" Background="#0d1015" BorderBrush="#22262d" BorderThickness="0,0,0,1">
                <Grid Margin="14,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="10" Height="10" Background="{StaticResource AccentBrush}" CornerRadius="5" Margin="0,0,8,0" />
                        <TextBlock x:Name="TitleBarTitleText" Text="NCS Console" Foreground="White" FontSize="{StaticResource FontSizeXl}" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <Button x:Name="SettingsToggleButton" Content="⚙ Settings" Style="{StaticResource PrimaryTabButtonStyle}" Tag="Inactive" ToolTip="Toggle settings panel" />
                        <Button x:Name="OperateToggleButton" Content="▶ Playbooks" Style="{StaticResource PrimaryTabButtonStyle}" Tag="Active" ToolTip="Toggle operate panel" />
                        <Button x:Name="ConsoleShowButton" Content="⌨ Console" Style="{StaticResource PrimaryTabButtonStyle}" Tag="Inactive" ToolTip="Toggle console panel" />
                        <Button x:Name="ReportsToggleButton" Content="📊 Reports" Style="{StaticResource PrimaryTabButtonStyle}" Tag="Inactive" Margin="0" ToolTip="Toggle reports panel" />
                    </StackPanel>
                    <Border Grid.Column="2" Background="Transparent" />
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MinimizeWindowButton" Style="{StaticResource TitleBarButtonStyle}">
                            <Path Width="10" Height="1" Stretch="Fill" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.5" Data="M0 0 L10 0" />
                        </Button>
                        <Button x:Name="MaximizeWindowButton" Style="{StaticResource TitleBarButtonStyle}">
                            <Path Width="10" Height="10" Stretch="Fill" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M0 0 L10 0 L10 10 L0 10 Z" />
                        </Button>
                        <Button x:Name="CloseWindowButton" Style="{StaticResource CloseTitleBarButtonStyle}">
                            <Path Width="10" Height="10" Stretch="Fill" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.5" Data="M0 0 L10 10 M10 0 L0 10" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="OperatePanel" Grid.Row="1" Margin="{StaticResource ContentMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SettingsColumn" Width="0" MinWidth="0" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition x:Name="ConsoleColumn" Width="0" MinWidth="0" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition x:Name="ReportsColumn" Width="0" MinWidth="0" />
                </Grid.ColumnDefinitions>

                <ScrollViewer x:Name="SettingsPanel" Grid.Column="0" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <Border Style="{StaticResource StatusCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="{StaticResource MarginSectionTitle}">
                                <TextBlock DockPanel.Dock="Left" Text="Settings" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                <Button x:Name="SettingsCloseButton" DockPanel.Dock="Right" Content="✕" Style="{StaticResource CloseTitleBarButtonStyle}" Width="24" Height="24" MinWidth="0" Padding="0" Margin="8,0,0,0" FontSize="{StaticResource FontSizeSm}" HorizontalAlignment="Right" ToolTip="Close settings" />
                            </DockPanel>
                            <TextBlock Text="SSH Ansible Host" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="SshHostTextBox" />
                            <TextBlock Text="SSH Ansible Host User" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="SshUserTextBox" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Port" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="SshPortTextBox" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Auth" Foreground="{StaticResource TextMutedBrush}" />
                                    <ComboBox x:Name="SshAuthModeComboBox" />
                                </StackPanel>
                            </Grid>
                            <StackPanel x:Name="SshKeyPathPanel">
                                <TextBlock Text="Key Path" Foreground="{StaticResource TextMutedBrush}" />
                                <TextBox x:Name="SshKeyPathTextBox" />
                            </StackPanel>
                            <StackPanel x:Name="SshPasswordPanel">
                                <TextBlock Text="Password" Foreground="{StaticResource TextMutedBrush}" />
                                <PasswordBox x:Name="SshPasswordBox" />
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="{StaticResource MarginDivider}" />
                            <TextBlock Text="Remote Ansible Project Path" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="RemoteRepoPathTextBox" />
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="{StaticResource MarginDivider}" />
                            <TextBlock Text="Reports" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="SMB Share Name" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="SmbShareNameTextBox" />
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="SMB User" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="SmbUserTextBox" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="SMB Password" Foreground="{StaticResource TextMutedBrush}" />
                                    <PasswordBox x:Name="SmbPasswordBox" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Delivery Mode" Foreground="{StaticResource TextMutedBrush}" />
                                    <ComboBox x:Name="ReportDeliveryModeComboBox" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Auto-refresh (sec)" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="AutoRefreshIntervalTextBox" />
                                </StackPanel>
                            </Grid>
                            <Button x:Name="SaveSettingsButton" Margin="{StaticResource MarginGapLg}" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="12" Height="12" Stretch="Uniform" Stroke="White" StrokeThickness="1.5" Fill="Transparent" Data="M2 0 L12 0 L14 2 L14 14 L0 14 L0 0 Z M4 0 L4 5 L10 5 L10 0 M4 8 L10 8 M4 10 L10 10" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="Save" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <GridSplitter x:Name="SettingsSplitter" Grid.Column="1" Width="4" Background="#2c3038" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="3,0" Visibility="Collapsed" />

                    <Grid x:Name="OperateContent" Grid.Column="2" HorizontalAlignment="Stretch">
                        <Border Style="{StaticResource StatusCardStyle}" Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Margin="{StaticResource MarginSectionTitle}">
                                    <TextBlock DockPanel.Dock="Left" Text="Playbooks" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="RefreshPlaybooksButton" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="4,2" FontSize="{StaticResource FontSizeSm}" ToolTip="Refresh playbooks and inventory" Visibility="Collapsed">
                                            <Path Width="10" Height="10" Stretch="Uniform" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M12 2 A8 8 0 1 0 14 8 M12 2 L16 2 L12 6" />
                                        </Button>
                                        <Button x:Name="PlaybooksCloseButton" Content="✕" Style="{StaticResource CloseTitleBarButtonStyle}" Width="24" Height="24" MinWidth="0" Padding="0" Margin="8,0,0,0" FontSize="{StaticResource FontSizeSm}" ToolTip="Close playbooks" />
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock x:Name="PlaybookPlaceholder" Grid.Row="1" Text="Connect to load playbooks" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeMd}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Grid x:Name="PlaybookSplitPane" Grid.Row="1" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="2*" MinWidth="180" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#12151a" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Margin="0,0,0,0">
                                        <ScrollViewer x:Name="ActionScrollViewer" VerticalScrollBarVisibility="Auto" Padding="4,4,0,4">
                                            <TreeView x:Name="ActionTreeView" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" FontFamily="{StaticResource FontMono}" Padding="0" ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                                        </ScrollViewer>
                                    </Border>
                                    <GridSplitter Grid.Column="1" Width="4" Background="#2c3038" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="3,0" />
                                    <ScrollViewer x:Name="ActionPropertiesPanel" Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="0" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock x:Name="ActionSelectionTitle" Text="Select a playbook" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeLg}" FontWeight="SemiBold" Margin="{StaticResource MarginSectionTitle}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="Target Host/Group (--limit)" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" />
                                            <TextBox x:Name="ActionLimitTextBox" ToolTip="--limit pattern: groups, hosts, wildcards (site*), negation (!host), intersection (:&amp;)" />
                                            <Border x:Name="ActionLimitTreeBorder" Visibility="Collapsed" Background="#12151a" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" MaxHeight="150" Margin="0,0,0,4">
                                                <ScrollViewer x:Name="ActionLimitTreeScroll" VerticalScrollBarVisibility="Auto" Padding="4,4,0,4">
                                                    <TreeView x:Name="ActionLimitTree" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeSm}" Padding="0" ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                                                </ScrollViewer>
                                            </Border>
                                            <TextBlock Text="Tags" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" />
                                            <TextBox x:Name="ActionTagsTextBox" ToolTip="--tags filter (comma-separated)" />
                                            <StackPanel x:Name="ActionOptionsPanel" Margin="{StaticResource MarginGapSm}" Visibility="Collapsed" />
                                            <Expander IsExpanded="False" Style="{StaticResource SectionExpanderStyle}" Margin="{StaticResource MarginGapSm}">
                                                <Expander.Header>
                                                    <TextBlock Text="Advanced" FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                                </Expander.Header>
                                                <StackPanel Margin="0,4,0,0">
                                                    <CheckBox x:Name="ActionCheckModeCheckBox" Content="Check mode (dry run)" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginGapSm}" />
                                                    <CheckBox x:Name="ActionDiffCheckBox" Content="Show diff" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" />
                                                    <TextBlock Text="Verbosity" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginGapSm}" />
                                                    <ComboBox x:Name="ActionVerbosityComboBox" ToolTip="Ansible verbosity level" />
                                                    <TextBlock Text="Extra Args" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginGapSm}" />
                                                    <TextBox x:Name="ExtraArgsTextBox" TextWrapping="Wrap" AcceptsReturn="True" Height="40" VerticalScrollBarVisibility="Auto" ToolTip="Additional ansible-playbook arguments" />
                                                </StackPanel>
                                            </Expander>
                                            <TextBlock x:Name="MutatingWarning" Text="⚠ This action makes changes to remote hosts" Foreground="{StaticResource DangerBrush}" FontSize="{StaticResource FontSizeSm}" Margin="0,8,0,0" Visibility="Collapsed" />
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Button x:Name="RunButton" ToolTip="Run selected action">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Width="12" Height="12" Stretch="Uniform" Fill="White" Data="M0 0 L10 5 L0 10 Z" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                        <TextBlock Text="Run" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="CancelButton" ToolTip="Cancel running action" Visibility="Collapsed">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Width="12" Height="12" Stretch="Uniform" Fill="{StaticResource DangerBrush}" Data="M0 0 L10 0 L10 10 L0 10 Z" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                        <TextBlock Text="Stop" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <GridSplitter x:Name="ConsoleSplitter" Grid.Column="3" Width="4" Background="#2c3038" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="3,0" Visibility="Collapsed" />

                    <Grid x:Name="ConsolePane" Grid.Column="4" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8,8,0,0" Padding="{StaticResource PaddingLg}">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Text="Console" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeMd}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="CopyOutputButton" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingSm}" FontSize="{StaticResource FontSizeMd}" ToolTip="Copy output to clipboard">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Width="10" Height="10" Stretch="Uniform" Stroke="{StaticResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M4 0 L12 0 L12 10 L4 10 Z M0 3 L0 13 L8 13 L8 10" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                <TextBlock Text="Copy" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ExportOutputButton" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingSm}" FontSize="{StaticResource FontSizeMd}" ToolTip="Export output to file">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Width="10" Height="10" Stretch="Uniform" Stroke="{StaticResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M5 0 L5 8 M2 5 L5 8 L8 5 M0 10 L10 10" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                <TextBlock Text="Export" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ConsoleToggleButton" Content="✕" Style="{StaticResource CloseTitleBarButtonStyle}" Width="24" Height="24" MinWidth="0" Padding="0" Margin="8,0,0,0" FontSize="{StaticResource FontSizeSm}" ToolTip="Collapse console" />
                                    </StackPanel>
                                </DockPanel>
                                <TextBox x:Name="CommandPreviewTextBox" IsReadOnly="True" TextWrapping="NoWrap" Background="#0d1015" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="{StaticResource MarginGapSm}" Padding="{StaticResource PaddingSm}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeSm}" Foreground="{StaticResource TextMutedBrush}" Visibility="Collapsed" />
                            </StackPanel>
                        </Border>

                        <RichTextBox x:Name="ConsoleTextBox" Grid.Row="1" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeLg}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#0d1015" Foreground="#d8dce2" CaretBrush="#d8dce2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1">
                            <RichTextBox.Resources>
                                <Style TargetType="Paragraph">
                                    <Setter Property="Margin" Value="0" />
                                </Style>
                            </RichTextBox.Resources>
                        </RichTextBox>

                        <Border x:Name="DetectedPathsPanel" Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" Padding="{StaticResource PaddingMd}" Visibility="Collapsed">
                            <Expander IsExpanded="False" Style="{StaticResource SectionExpanderStyle}" Margin="0">
                                <Expander.Header>
                                    <TextBlock Text="Detected Paths" FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                </Expander.Header>
                                <ListBox x:Name="DetectedPathsListBox" Margin="{StaticResource MarginGapSm}" MaxHeight="100" BorderThickness="0" Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}" ItemTemplate="{StaticResource PathItemTemplate}" />
                            </Expander>
                        </Border>
                    </Grid>

                    <GridSplitter x:Name="ReportsSplitter" Grid.Column="5" Width="4" Background="#2c3038" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="3,0" Visibility="Collapsed" />

                    <Grid x:Name="ReportsPane" Grid.Column="6" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8,8,0,0" Padding="{StaticResource PaddingLg}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="Reports" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeMd}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="ReportBackButton" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingSm}" FontSize="{StaticResource FontSizeMd}" ToolTip="Back" IsEnabled="False">
                                        <Path Width="8" Height="10" Stretch="Uniform" Stroke="{StaticResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M8 0 L0 5 L8 10" VerticalAlignment="Center" />
                                    </Button>
                                    <Button x:Name="ReportHomeButton" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingSm}" FontSize="{StaticResource FontSizeMd}" ToolTip="Site report">
                                        <Path Width="10" Height="10" Stretch="Uniform" Stroke="{StaticResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M5 0 L10 5 L10 10 L0 10 L0 5 Z" VerticalAlignment="Center" />
                                    </Button>
                                    <Button x:Name="ReportRefreshButton" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingSm}" FontSize="{StaticResource FontSizeMd}" ToolTip="Refresh">
                                        <Path Width="10" Height="10" Stretch="Uniform" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M12 2 A8 8 0 1 0 14 8 M12 2 L16 2 L12 6" VerticalAlignment="Center" />
                                    </Button>
                                    <Button x:Name="ReportsMaximizeButton" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingSm}" FontSize="{StaticResource FontSizeMd}" ToolTip="Maximize reports" Margin="4,0,0,0">
                                        <Path Width="10" Height="10" Stretch="Uniform" Stroke="{StaticResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M0 0 L10 0 L10 10 L0 10 Z" VerticalAlignment="Center" />
                                    </Button>
                                    <Button x:Name="ReportsCloseButton" Content="✕" Style="{StaticResource CloseTitleBarButtonStyle}" Width="24" Height="24" MinWidth="0" Padding="0" Margin="8,0,0,0" FontSize="{StaticResource FontSizeSm}" ToolTip="Collapse reports" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" ClipToBounds="True">
                            <Grid>
                                <Grid x:Name="ReportHost" Background="#0f1117" />
                                <Border x:Name="ReportPlaceholderPanel" Background="#0f1117">
                                    <TextBlock x:Name="ReportPlaceholder" Text="Connect to sync reports to view them inline" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeMd}" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" Margin="20" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="PreflightButton" Grid.Column="0" MinWidth="0" Margin="0" Padding="12,0" VerticalAlignment="Stretch" ToolTip="Connect to remote host" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0,1,1,0" BorderBrush="#22262d">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="PreflightButtonText" Text="⚡ Connect" VerticalAlignment="Center" FontSize="{StaticResource FontSizeSm}" />
                </Button>
                <Border Grid.Column="1" Background="#0d1015" BorderBrush="#22262d" BorderThickness="0,1,0,0" Padding="{StaticResource PaddingBar}">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ConnectionInfoText" Grid.Column="0" Text="" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeMd}" VerticalAlignment="Center" />
                    <Border x:Name="RunStateBorder" Grid.Column="1" Visibility="Collapsed" Background="#1e2228" CornerRadius="{StaticResource RadiusSm}" Padding="{StaticResource PaddingBadgeSm}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="RunStateText" Text="Idle" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeXs}" FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Text=" · " Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeXs}" VerticalAlignment="Center" />
                            <TextBlock x:Name="RunMetaText" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeXs}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="StatusTextBlock" Grid.Column="2" Text="Ready." TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeMd}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="{StaticResource MarginStatusItem}" />
                    <StackPanel x:Name="ExitCodePanel" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MarginStatusItem}" Visibility="Collapsed">
                        <TextBlock Text="Exit:" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginLabelValue}" />
                        <TextBlock x:Name="ExitCodeTextBlock" Text="-" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel x:Name="DurationPanel" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MarginStatusItem}" Visibility="Collapsed">
                        <TextBlock Text="Duration:" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginLabelValue}" />
                        <TextBlock x:Name="DurationTextBlock" Text="-" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
