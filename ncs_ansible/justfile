# Run only Ubuntu discovery phase
audit-ubuntu-discover:
    {{ ansible_playbook }} playbooks/ubuntu_discover.yml

# Run only the Windows audit
audit-windows:
    {{ ansible_playbook }} playbooks/windows_audit.yml

# Run only Windows update apply phase
update-windows:
    {{ ansible_playbook }} playbooks/windows_update.yml

# Run Windows post-patch audit phase
audit-windows-post-patch:
    {{ ansible_playbook }} playbooks/windows_post_patch_audit.yml

# --- Targeted Orchestration ---

# Run STIG Audit for a specific VM on a specific vCenter
# Example: just stig-audit-vm vc-01 my-vm-01
stig-audit-vm vcenter vm_name:
    {{ ansible_playbook }} playbooks/vmware_vm_stig_audit.yml -l {{ vcenter }} -e "vm_stig_target_vms=['{{ vm_name }}']"

# Run STIG Hardening for a specific VM on a specific vCenter (MUTATING)
stig-harden-vm vcenter vm_name:
    {{ ansible_playbook }} playbooks/vmware_vm_stig_remediate.yml -l {{ vcenter }} -e "vm_stig_target_vms=['{{ vm_name }}']"

# Run STIG Audit for a specific ESXi host on a specific vCenter
# Example: just stig-audit-esxi vc-01 esxi-01.local
stig-audit-esxi vcenter host:
    {{ ansible_playbook }} playbooks/vmware_esxi_stig_audit.yml -l {{ vcenter }} -e "esxi_stig_target_hosts=['{{ host }}']"

# Run ESXi STIG audit for all ESXi hosts in a site
# Example: just stig-audit-esxi-site sdhm
stig-audit-esxi-site site:
    tmpfile=$$(mktemp /tmp/ncs_esxi_site_XXXXXX.json); \
    {{ ansible_inventory }} -i {{ inventory_file }} --list | {{ python }} -c 'import json,sys; d=json.load(sys.stdin); site="{{ site }}";\n\ndef walk(g, seen=None):\n    seen = seen or set()\n    if g in seen:\n        return set()\n    seen.add(g)\n    node=d.get(g,{})\n    hosts=set(node.get("hosts",[]))\n    for c in node.get("children",[]):\n        hosts |= walk(c, seen)\n    return hosts\n\nesxi_all=walk("esxi_hosts"); hosts=sorted(walk(site) & esxi_all); (hosts and print(json.dumps({"esxi_stig_target_hosts": hosts}))) or (_ for _ in ()).throw(SystemExit("no ESXi hosts found for site "+site))' > "$$tmpfile"; \
    {{ ansible_playbook }} playbooks/vmware_esxi_stig_audit.yml -l {{ site }} -e "@$$tmpfile"; \
    rm -f "$$tmpfile"

# Run ESXi STIG audit for all ESXi hosts in a site using a custom inventory file
# Example: just stig-audit-esxi-site-inv sdhm inventory/production/hosts.yaml
stig-audit-esxi-site-inv site inv:
    tmpfile=$$(mktemp /tmp/ncs_esxi_site_XXXXXX.json); \
    {{ ansible_inventory }} -i {{ inv }} --list | {{ python }} -c 'import json,sys; d=json.load(sys.stdin); site="{{ site }}";\n\ndef walk(g, seen=None):\n    seen = seen or set()\n    if g in seen:\n        return set()\n    seen.add(g)\n    node=d.get(g,{})\n    hosts=set(node.get("hosts",[]))\n    for c in node.get("children",[]):\n        hosts |= walk(c, seen)\n    return hosts\n\nesxi_all=walk("esxi_hosts"); hosts=sorted(walk(site) & esxi_all); (hosts and print(json.dumps({"esxi_stig_target_hosts": hosts}))) or (_ for _ in ()).throw(SystemExit("no ESXi hosts found for site "+site))' > "$$tmpfile"; \
    {{ ansible_playbook }} -i {{ inv }} playbooks/vmware_esxi_stig_audit.yml -l {{ site }} -e "@$$tmpfile"; \
    rm -f "$$tmpfile"

# Run STIG Hardening for a specific ESXi host on a specific vCenter (MUTATING)
stig-harden-esxi vcenter host:
    {{ ansible_playbook }} playbooks/vmware_esxi_stig_remediate.yml -l {{ vcenter }} -e "esxi_stig_target_hosts=['{{ host }}']"

