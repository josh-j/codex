<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="NCS UI"
    Height="860"
    Width="1360"
    MinHeight="720"
    MinWidth="1180"
    WindowStartupLocation="CenterScreen"
    Background="#F4F1EB"
    FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFDF9" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F5A5A" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#D7ECE8" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D2C8B7" />
        <SolidColorBrush x:Key="TextBrush" Color="#202020" />
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E5DED0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#E5DED0" />
        </Style>
        <Style x:Key="StatusCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="24" Padding="24" Background="#113B42" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="NCS UI" Foreground="White" FontSize="28" FontWeight="Bold" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Foreground="#E8F6F4"
                        FontSize="14"
                        Text="Remote operator console for ansible-ncs workflows. Preflight first, then run safe actions with live output." />
                </StackPanel>
                <Border
                    x:Name="RunStateBorder"
                    Grid.Column="1"
                    Background="#1C6466"
                    CornerRadius="18"
                    Padding="16"
                    HorizontalAlignment="Right">
                    <StackPanel>
                        <TextBlock Text="Run State" Foreground="#D9F0EE" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock x:Name="RunStateText" Text="Idle" Foreground="White" FontSize="22" FontWeight="Bold" />
                        <TextBlock x:Name="RunMetaText" Margin="0,6,0,0" Foreground="#D9F0EE" Text="No command started yet." />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0">
                <StackPanel>
                    <Border Style="{StaticResource StatusCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Remote Target" FontSize="18" FontWeight="Bold" />
                            <TextBlock Margin="0,12,0,0" Text="SSH Host *" />
                            <TextBox x:Name="SshHostTextBox" />
                            <TextBlock Text="SSH Port" />
                            <TextBox x:Name="SshPortTextBox" />
                            <TextBlock Text="SSH User *" />
                            <TextBox x:Name="SshUserTextBox" />
                            <TextBlock Text="SSH Auth Mode" />
                            <ComboBox x:Name="SshAuthModeComboBox" />
                            <StackPanel x:Name="SshKeyPathPanel">
                                <TextBlock Text="SSH Key Path" />
                                <TextBox x:Name="SshKeyPathTextBox" />
                            </StackPanel>
                            <StackPanel x:Name="SshPasswordPanel">
                                <TextBlock Text="SSH Password" />
                                <PasswordBox x:Name="SshPasswordBox" />
                            </StackPanel>
                            <TextBlock Text="Remote Repo Path *" />
                            <TextBox x:Name="RemoteRepoPathTextBox" />
                            <TextBlock Text="Remote Vault Path *" />
                            <TextBox x:Name="RemoteVaultPathTextBox" />
                            <TextBlock Text="Default Site" />
                            <TextBox x:Name="DefaultSiteTextBox" />
                            <TextBlock Text="Default Ansible Host" />
                            <TextBox x:Name="DefaultHostTextBox" />
                            <WrapPanel Margin="0,8,0,0">
                                <Button x:Name="SaveSettingsButton" Content="Save Settings" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button x:Name="PreflightButton" Content="Run Preflight" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatusCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Preflight Checks" FontSize="18" FontWeight="Bold" />
                            <TextBlock
                                x:Name="PreflightSummaryText"
                                Margin="0,10,0,10"
                                Text="Preflight has not been run."
                                TextWrapping="Wrap" />
                            <ListBox x:Name="PreflightListBox" Height="220" BorderThickness="0" Background="#FFFDF9" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0">
                <StackPanel>
                    <Border Style="{StaticResource StatusCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Action" FontSize="18" FontWeight="Bold" />
                            <TextBlock Margin="0,12,0,0" Text="Select Action" />
                            <ComboBox x:Name="ActionComboBox" />
                            <TextBlock Text="Site Limit" />
                            <TextBox x:Name="SiteTextBox" />
                            <TextBlock Text="Ansible Host" />
                            <TextBox x:Name="HostTextBox" />
                            <TextBlock Text="Extra Args" />
                            <TextBox x:Name="ExtraArgsTextBox" TextWrapping="Wrap" AcceptsReturn="True" Height="84" VerticalScrollBarVisibility="Auto" />
                            <WrapPanel Margin="0,12,0,0">
                                <Button x:Name="RunButton" Content="Run Action" />
                                <Button x:Name="CancelButton" Content="Cancel Run" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                            <TextBlock
                                Margin="0,10,0,0"
                                Foreground="#555"
                                TextWrapping="Wrap"
                                Text="`Run Site` requires a site value. `Run Host` and `Inventory Host` require an Ansible host. `Extra Args` are appended to the remote command verbatim, so keep them operator-safe." />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatusCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Run Details" FontSize="18" FontWeight="Bold" />
                            <TextBlock Margin="0,12,0,0" Text="Command" />
                            <TextBox x:Name="CommandPreviewTextBox" IsReadOnly="True" Height="78" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                            <TextBlock Margin="0,8,0,0" Text="Detected Paths" />
                            <ListBox x:Name="DetectedPathsListBox" Height="120" BorderThickness="0" Background="#FFFDF9" />
                            <WrapPanel Margin="0,12,0,0">
                                <Button x:Name="CopyOutputButton" Content="Copy Output" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button x:Name="ExportOutputButton" Content="Export Output" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2" Style="{StaticResource StatusCardStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock DockPanel.Dock="Left" Text="Live Console" FontSize="18" FontWeight="Bold" />
                        <TextBlock x:Name="ConsoleHintText" DockPanel.Dock="Right" Foreground="#555" Text="Output appears here in time order." />
                    </DockPanel>
                    <TextBox
                        x:Name="ConsoleTextBox"
                        Grid.Row="1"
                        FontFamily="Consolas"
                        FontSize="13"
                        IsReadOnly="True"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto"
                        Background="#191919"
                        Foreground="#EDEDED"
                        BorderThickness="0" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFDF9" CornerRadius="16" Padding="16" BorderBrush="#D2C8B7" BorderThickness="1" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Status" FontWeight="Bold" />
                    <TextBlock x:Name="StatusTextBlock" Text="Ready to configure." TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Exit Code" FontWeight="Bold" />
                    <TextBlock x:Name="ExitCodeTextBlock" Text="-" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Duration" FontWeight="Bold" />
                    <TextBlock x:Name="DurationTextBlock" Text="-" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
