<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="NCS UI"
    Height="900"
    Width="1440"
    MinHeight="760"
    MinWidth="1220"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResize"
    Background="#111217"
    FontFamily="Segoe UI">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="44"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#181b1f" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1e2228" />
        <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#242932" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7fb069" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#1f3326" />
        <SolidColorBrush x:Key="WarnBrush" Color="#d6a24a" />
        <SolidColorBrush x:Key="WarnSoftBrush" Color="#352a19" />
        <SolidColorBrush x:Key="DangerBrush" Color="#f06478" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#381e24" />
        <SolidColorBrush x:Key="InfoBrush" Color="#78a9ff" />
        <SolidColorBrush x:Key="InfoSoftBrush" Color="#182742" />
        <SolidColorBrush x:Key="BorderBrush" Color="#2c3038" />
        <SolidColorBrush x:Key="TextBrush" Color="#d8dce2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8e939c" />

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="#d8dce2" />
            <Setter Property="CaretBrush" Value="#d8dce2" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="#d8dce2" />
            <Setter Property="CaretBrush" Value="#d8dce2" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="#d8dce2" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#10140f" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#171a20" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style x:Key="StatusCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
        <Style x:Key="SectionExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <DataTemplate x:Key="PreflightItemTemplate">
            <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="StatusBadge" Width="52" Height="24" CornerRadius="12" Background="{StaticResource DangerSoftBrush}" VerticalAlignment="Top">
                        <TextBlock x:Name="StatusBadgeText" Text="FAIL" Foreground="{StaticResource DangerBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding Message}" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Passed}" Value="True">
                    <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                    <Setter TargetName="StatusBadgeText" Property="Text" Value="PASS" />
                    <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="PathItemTemplate">
            <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="#0f1117" BorderBrush="#2c3038" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="TitleBarDragRegion" Grid.Row="0" Background="#0d1015" BorderBrush="#22262d" BorderThickness="0,0,0,1">
                <Grid Margin="16,10,12,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="12" Height="12" Background="{StaticResource AccentBrush}" CornerRadius="6" Margin="0,0,10,0" />
                        <StackPanel>
                            <TextBlock x:Name="TitleBarTitleText" Text="NCS UI" Foreground="White" FontSize="14" FontWeight="Bold" />
                            <TextBlock x:Name="TitleBarSubtitleText" Text="Operator console for ansible-ncs" Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Margin="18,0,0,0" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="12,6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="State" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="TitleBarRunStateText" Text="Idle" Foreground="{StaticResource TextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <WrapPanel Grid.Column="2" VerticalAlignment="Center" Margin="18,0,0,0">
                        <Button x:Name="MinimizeWindowButton" Content="-" Style="{StaticResource TitleBarButtonStyle}" />
                        <Button x:Name="MaximizeWindowButton" Content="□" Style="{StaticResource TitleBarButtonStyle}" />
                        <Button x:Name="CloseWindowButton" Content="X" Style="{StaticResource TitleBarButtonStyle}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="12" Padding="24" Background="#171a20" BorderBrush="#2c3038" BorderThickness="1" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="290" />
                            <ColumnDefinition Width="290" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="NCS UI" Foreground="White" FontSize="30" FontWeight="Bold" />
                            <TextBlock
                                Margin="0,8,0,0"
                                Foreground="{StaticResource TextMutedBrush}"
                                FontSize="14"
                                TextWrapping="Wrap"
                                Text="A staged operator console for ansible-ncs. Connect once, validate the target, then run the narrowest safe action with live output." />
                        </StackPanel>
                        <Border Grid.Column="1" Margin="12,0,12,0" Background="{StaticResource SurfaceAltBrush}" CornerRadius="10" Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Setup" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                <TextBlock x:Name="SetupSummaryText" Text="Connection details need review." Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" Text="Stage 1: confirm remote host, auth, and defaults." TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border
                            x:Name="RunStateBorder"
                            Grid.Column="2"
                            Background="#1e2228"
                            CornerRadius="10"
                            Padding="16"
                            BorderBrush="#2c3038"
                            BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Run State" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                <TextBlock x:Name="RunStateText" Text="Idle" Foreground="White" FontSize="22" FontWeight="Bold" />
                                <TextBlock x:Name="RunMetaText" Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" Text="No command started yet." TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="430" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0">
                <StackPanel>
                    <Border Style="{StaticResource StatusCardStyle}">
                        <StackPanel>
                            <TextBlock Text="1. Connect And Validate" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Margin="0,8,0,16" Text="Keep the required connection fields upfront and move defaults into secondary panels." Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />

                            <Expander IsExpanded="True" Style="{StaticResource SectionExpanderStyle}">
                                <Expander.Header>
                                    <StackPanel>
                                        <TextBlock Text="Connection" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Remote target and SSH authentication." Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="SSH Host *" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="SshHostTextBox" />
                                    <TextBlock Text="SSH User *" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="SshUserTextBox" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="SSH Port" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBox x:Name="SshPortTextBox" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="SSH Auth Mode" Foreground="{StaticResource TextMutedBrush}" />
                                            <ComboBox x:Name="SshAuthModeComboBox" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel x:Name="SshKeyPathPanel">
                                        <TextBlock Text="SSH Key Path" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBox x:Name="SshKeyPathTextBox" />
                                    </StackPanel>
                                    <StackPanel x:Name="SshPasswordPanel">
                                        <TextBlock Text="SSH Password" Foreground="{StaticResource TextMutedBrush}" />
                                        <PasswordBox x:Name="SshPasswordBox" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <Expander IsExpanded="False" Style="{StaticResource SectionExpanderStyle}">
                                <Expander.Header>
                                    <StackPanel>
                                        <TextBlock Text="Remote Paths" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Repository and vault locations used during remote runs." Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="Remote Repo Path *" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="RemoteRepoPathTextBox" />
                                    <TextBlock Text="Remote Vault Path *" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="RemoteVaultPathTextBox" />
                                </StackPanel>
                            </Expander>

                            <Expander IsExpanded="False" Style="{StaticResource SectionExpanderStyle}">
                                <Expander.Header>
                                    <StackPanel>
                                        <TextBlock Text="Defaults" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Optional values that pre-fill narrower runs." Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="Default Site" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="DefaultSiteTextBox" />
                                    <TextBlock Text="Default Ansible Host" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="DefaultHostTextBox" />
                                </StackPanel>
                            </Expander>

                            <WrapPanel Margin="0,8,0,0">
                                <Button x:Name="SaveSettingsButton" Content="Save Settings" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button x:Name="PreflightButton" Content="Run Preflight" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatusCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock DockPanel.Dock="Left" Text="Preflight" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                                <Border x:Name="PreflightStateBadge" DockPanel.Dock="Right" Background="{StaticResource WarnSoftBrush}" CornerRadius="12" Padding="10,4">
                                    <TextBlock x:Name="PreflightStateText" Text="Not Run" Foreground="{StaticResource WarnBrush}" FontWeight="SemiBold" />
                                </Border>
                            </DockPanel>
                            <TextBlock
                                x:Name="PreflightSummaryText"
                                Margin="0,0,0,12"
                                Text="Preflight has not been run."
                                Foreground="{StaticResource TextMutedBrush}"
                                TextWrapping="Wrap" />
                            <ListBox x:Name="PreflightListBox" BorderThickness="0" Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}" ItemTemplate="{StaticResource PreflightItemTemplate}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0">
                <StackPanel>
                    <Border Style="{StaticResource StatusCardStyle}">
                        <StackPanel>
                            <TextBlock Text="2. Plan The Run" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Margin="0,8,0,16" Text="Choose the smallest action that answers the question, then only expose the scope inputs that matter." Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />

                            <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Selected Action" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                    <TextBlock x:Name="ActionSummaryText" Text="Run the full workflow across all targets." Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                                    <TextBlock x:Name="ScopeRequirementText" Margin="0,6,0,0" Foreground="{StaticResource InfoBrush}" Text="No extra scope value required." TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Select Action" Foreground="{StaticResource TextMutedBrush}" />
                            <ComboBox x:Name="ActionComboBox" />

                            <Border Background="{StaticResource InfoSoftBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Scope" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                    <TextBlock Text="Only the relevant limit field stays active for the current action." Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Site Limit" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="SiteTextBox" />
                            <TextBlock Text="Ansible Host" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="HostTextBox" />

                            <Expander IsExpanded="False" Style="{StaticResource SectionExpanderStyle}">
                                <Expander.Header>
                                    <StackPanel>
                                        <TextBlock Text="Advanced Arguments" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Optional raw arguments appended to the remote command." Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="Extra Args" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="ExtraArgsTextBox" TextWrapping="Wrap" AcceptsReturn="True" Height="92" VerticalScrollBarVisibility="Auto" />
                                    <TextBlock
                                        Foreground="#6c727d"
                                        TextWrapping="Wrap"
                                        Text="Raw arguments are appended verbatim. Treat this as an escape hatch for operators who know exactly what they need." />
                                </StackPanel>
                            </Expander>

                            <WrapPanel Margin="0,12,0,0">
                                <Button x:Name="RunButton" Content="Run Action" />
                                <Button x:Name="CancelButton" Content="Cancel Run" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatusCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock DockPanel.Dock="Left" Text="Run Preview" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="CommandReadinessText" DockPanel.Dock="Right" Foreground="{StaticResource TextMutedBrush}" Text="Preview updates live." />
                            </DockPanel>
                            <TextBlock Margin="0,0,0,8" Text="Command" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="CommandPreviewTextBox" IsReadOnly="True" Height="90" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />

                            <Expander IsExpanded="False" Style="{StaticResource SectionExpanderStyle}">
                                <Expander.Header>
                                    <StackPanel>
                                        <TextBlock Text="Detected Paths" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Artifacts surfaced after a run finishes." Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="0,14,0,0">
                                    <ListBox x:Name="DetectedPathsListBox" BorderThickness="0" Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}" ItemTemplate="{StaticResource PathItemTemplate}" />
                                </StackPanel>
                            </Expander>

                            <WrapPanel Margin="0,12,0,0">
                                <Button x:Name="CopyOutputButton" Content="Copy Output" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button x:Name="ExportOutputButton" Content="Export Output" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2" Style="{StaticResource StatusCardStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="3. Observe Output" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                        <TextBlock x:Name="ConsoleHintText" Margin="0,6,0,0" Foreground="#6c727d" Text="Live console output streams here in time order." TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBox
                        x:Name="ConsoleTextBox"
                        Grid.Row="1"
                        FontFamily="Consolas"
                        FontSize="13"
                        IsReadOnly="True"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto"
                        Background="#101319"
                        Foreground="#d8dce2"
                        CaretBrush="#d8dce2"
                        BorderThickness="0" />
                </Grid>
            </Border>
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource StatusCardStyle}" Margin="0,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Status" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="StatusTextBlock" Text="Ready to configure." TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Exit Code" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="ExitCodeTextBlock" Text="-" Foreground="{StaticResource TextBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Duration" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="DurationTextBlock" Text="-" Foreground="{StaticResource TextBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
