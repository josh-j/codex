<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="NCS UI"
    Height="800"
    Width="900"
    MinHeight="600"
    MinWidth="900"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResize"
    Background="#111217"
    FontFamily="Segoe UI">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#181b1f" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1e2228" />
        <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#242932" />
        <SolidColorBrush x:Key="AccentBrush" Color="#6e9fff" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#182742" />
        <SolidColorBrush x:Key="WarnBrush" Color="#d6a24a" />
        <SolidColorBrush x:Key="WarnSoftBrush" Color="#352a19" />
        <SolidColorBrush x:Key="DangerBrush" Color="#f06478" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#381e24" />
        <SolidColorBrush x:Key="InfoBrush" Color="#78a9ff" />
        <SolidColorBrush x:Key="InfoSoftBrush" Color="#182742" />
        <SolidColorBrush x:Key="BorderBrush" Color="#2c3038" />
        <SolidColorBrush x:Key="TextBrush" Color="#d8dce2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8e939c" />

        <CornerRadius x:Key="RadiusSm">4</CornerRadius>
        <CornerRadius x:Key="RadiusMd">6</CornerRadius>
        <CornerRadius x:Key="RadiusLg">8</CornerRadius>
        <Thickness x:Key="InputMargin">0,3,0,6</Thickness>
        <Thickness x:Key="InputPadding">8,5,8,5</Thickness>
        <Thickness x:Key="CardPadding">12</Thickness>
        <Thickness x:Key="CardMargin">0,0,0,8</Thickness>
        <Thickness x:Key="ContentMargin">8</Thickness>
        <Thickness x:Key="SectionGap">0,6,0,0</Thickness>
        <FontFamily x:Key="FontUI">Segoe UI</FontFamily>
        <FontFamily x:Key="FontMono">Consolas</FontFamily>
        <sys:Double x:Key="FontSizeXs">9</sys:Double>
        <sys:Double x:Key="FontSizeSm">10</sys:Double>
        <sys:Double x:Key="FontSizeMd">11</sys:Double>
        <sys:Double x:Key="FontSizeLg">12</sys:Double>
        <sys:Double x:Key="FontSizeXl">13</sys:Double>
        <sys:Double x:Key="FontSizeTitle">14</sys:Double>

        <Thickness x:Key="MarginGapSm">0,4,0,0</Thickness>
        <Thickness x:Key="MarginGapMd">0,6,0,0</Thickness>
        <Thickness x:Key="MarginGapLg">0,8,0,0</Thickness>
        <Thickness x:Key="MarginStatusItem">10,0,0,0</Thickness>
        <Thickness x:Key="MarginLabelValue">0,0,4,0</Thickness>
        <Thickness x:Key="MarginInlineSm">0,0,4,0</Thickness>
        <Thickness x:Key="MarginInlineMd">8,0,0,0</Thickness>
        <Thickness x:Key="MarginDivider">0,10,0,10</Thickness>
        <Thickness x:Key="MarginTabPanel">0,0,0,6</Thickness>
        <Thickness x:Key="MarginSectionTitle">0,0,0,6</Thickness>

        <Thickness x:Key="PaddingXs">4,2,4,2</Thickness>
        <Thickness x:Key="PaddingSm">6,3,6,3</Thickness>
        <Thickness x:Key="PaddingMd">8,4,8,4</Thickness>
        <Thickness x:Key="PaddingLg">10,6,10,6</Thickness>
        <Thickness x:Key="PaddingPill">8,2,8,2</Thickness>
        <Thickness x:Key="PaddingTab">12,4,12,4</Thickness>
        <Thickness x:Key="PaddingBar">12,0,12,0</Thickness>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="{StaticResource InputMargin}" />
            <Setter Property="Padding" Value="{StaticResource InputPadding}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="#d8dce2" />
            <Setter Property="CaretBrush" Value="#d8dce2" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="{StaticResource InputMargin}" />
            <Setter Property="Padding" Value="{StaticResource InputPadding}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="#d8dce2" />
            <Setter Property="CaretBrush" Value="#d8dce2" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="{StaticResource InputMargin}" />
            <Setter Property="Padding" Value="{StaticResource InputPadding}" />
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="#d8dce2" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template" Value="{DynamicResource NcsComboBoxTemplate}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#0d1015" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinWidth" Value="70" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{StaticResource RadiusLg}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1e2228" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#171a20" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20252d" />
                    <Setter Property="BorderBrush" Value="#3a4250" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#282f38" />
                    <Setter Property="BorderBrush" Value="#465162" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
            <Setter Property="Padding" Value="{StaticResource CardPadding}" />
            <Setter Property="Margin" Value="{StaticResource CardMargin}" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" Margin="{StaticResource MarginTabPanel}" IsItemsHost="True" />
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="#151920" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource PaddingTab}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#3c4654" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#3c4654" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SectionExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="Transparent">
                            <StackPanel>
                                <ToggleButton x:Name="HeaderSite" Background="Transparent" BorderThickness="0" Foreground="{TemplateBinding Foreground}" Focusable="False" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="{StaticResource PaddingMd}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" />
                                            <TextBlock x:Name="ExpanderGlyph" Grid.Column="1" Text="+" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeXl}" FontWeight="Bold" VerticalAlignment="Center" Margin="{StaticResource MarginInlineMd}" />
                                        </Grid>
                                    </Border>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed" Margin="{StaticResource MarginGapMd}" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                <Setter TargetName="ExpanderGlyph" Property="Text" Value="-" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusLg}" SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1a1f27" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1d2834" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeLg}" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="IsExpanded" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusMd}" Padding="{TemplateBinding Padding}" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="Glyph" Grid.Column="0" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeLg}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="20,0,0,0" Visibility="Collapsed" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Glyph" Property="Text" Value=" ▶" />
                                <Setter TargetName="Glyph" Property="FontSize" Value="8" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Glyph" Property="Text" Value="[+]" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Glyph" Property="Text" Value="[-]" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#182742" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1a1f27" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NcsScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="#151820" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NcsScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#3d4654" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="{TemplateBinding Background}" CornerRadius="6" Margin="2" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#58657a" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#78a9ff" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="#151820" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource NcsScrollBarRepeatButtonStyle}" Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource NcsScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource NcsScrollBarRepeatButtonStyle}" Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="12" />
                                <Setter Property="Width" Value="Auto" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ComboItemBorder" Background="{TemplateBinding Background}" CornerRadius="6" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ComboItemBorder" Property="Background" Value="#25303c" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ComboItemBorder" Property="Background" Value="#182742" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComboBoxToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}" BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}" BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="36" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1" Background="#161920" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" CornerRadius="0,8,8,0">
                                    <TextBlock Text="▾" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="NcsComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton Name="ToggleButton" Style="{StaticResource ComboBoxToggleButtonStyle}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False" />
                <ContentPresenter Margin="10,5,40,5" VerticalAlignment="Center" HorizontalAlignment="Left" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                    <Border Background="#171b21" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource PaddingSm}" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                        <ScrollViewer>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
        </ControlTemplate>
        <DataTemplate x:Key="PreflightItemTemplate">
            <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="{StaticResource PaddingSm}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="StatusBadge" Width="40" Height="18" CornerRadius="9" Background="{StaticResource DangerSoftBrush}" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusBadgeText" Text="FAIL" Foreground="{StaticResource DangerBrush}" FontSize="{StaticResource FontSizeXs}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="{StaticResource MarginInlineMd}">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeLg}" Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="{StaticResource FontSizeMd}" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Passed}" Value="True">
                    <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                    <Setter TargetName="StatusBadgeText" Property="Text" Value="PASS" />
                    <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="PathItemTemplate">
            <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource PaddingLg}">
                <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="#0f1117" BorderBrush="#2c3038" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <Border x:Name="TitleBarDragRegion" Grid.Row="0" Background="#0d1015" BorderBrush="#22262d" BorderThickness="0,0,0,1">
                <Grid Margin="14,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="10" Height="10" Background="{StaticResource AccentBrush}" CornerRadius="5" Margin="0,0,8,0" />
                        <TextBlock x:Name="TitleBarTitleText" Text="NCS UI" Foreground="White" FontSize="{StaticResource FontSizeXl}" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock x:Name="TitleBarSubtitleText" Visibility="Collapsed" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <Button x:Name="SettingsToggleButton" Content="⚙ Settings" MinWidth="0" Padding="{StaticResource PaddingTab}" FontSize="{StaticResource FontSizeMd}" FontWeight="SemiBold" Background="#151920" Foreground="{StaticResource TextMutedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="{StaticResource MarginLabelValue}" ToolTip="Toggle settings panel" />
                        <Button x:Name="ConsoleShowButton" Content="▸ Console" MinWidth="0" Padding="{StaticResource PaddingTab}" FontSize="{StaticResource FontSizeMd}" FontWeight="SemiBold" Background="#151920" Foreground="{StaticResource TextMutedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ToolTip="Toggle console panel" />
                    </StackPanel>
                    <Border Grid.Column="2" Background="Transparent" />
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MinimizeWindowButton" Content="-" Style="{StaticResource TitleBarButtonStyle}" />
                        <Button x:Name="MaximizeWindowButton" Content="□" Style="{StaticResource TitleBarButtonStyle}" />
                        <Button x:Name="CloseWindowButton" Content="X" Style="{StaticResource TitleBarButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="OperatePanel" Grid.Row="1" Margin="{StaticResource ContentMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SettingsColumn" Width="0" MinWidth="0" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="250" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition x:Name="ConsoleColumn" Width="0" MinWidth="0" />
                </Grid.ColumnDefinitions>

                <ScrollViewer x:Name="SettingsPanel" Grid.Column="0" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <Border Style="{StaticResource StatusCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="{StaticResource MarginSectionTitle}">
                                <TextBlock DockPanel.Dock="Left" Text="Settings" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                <Button x:Name="SettingsCloseButton" DockPanel.Dock="Right" Content="✕" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingPill}" FontSize="{StaticResource FontSizeSm}" HorizontalAlignment="Right" ToolTip="Close settings" />
                            </DockPanel>
                            <TextBlock Text="SSH Host" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="SshHostTextBox" />
                            <TextBlock Text="SSH User" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="SshUserTextBox" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Port" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox x:Name="SshPortTextBox" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Auth" Foreground="{StaticResource TextMutedBrush}" />
                                    <ComboBox x:Name="SshAuthModeComboBox" />
                                </StackPanel>
                            </Grid>
                            <StackPanel x:Name="SshKeyPathPanel">
                                <TextBlock Text="Key Path" Foreground="{StaticResource TextMutedBrush}" />
                                <TextBox x:Name="SshKeyPathTextBox" />
                            </StackPanel>
                            <StackPanel x:Name="SshPasswordPanel">
                                <TextBlock Text="Password" Foreground="{StaticResource TextMutedBrush}" />
                                <PasswordBox x:Name="SshPasswordBox" />
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="{StaticResource MarginDivider}" />
                            <TextBlock Text="Repo Path" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="RemoteRepoPathTextBox" />
                            <TextBlock Text="Vault Path" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="RemoteVaultPathTextBox" />
                            <TextBlock Text="Default Site" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="DefaultSiteTextBox" />
                            <TextBlock Text="Default Host" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox x:Name="DefaultHostTextBox" />
                            <Button x:Name="SaveSettingsButton" Content="Save Settings" Margin="{StaticResource MarginGapLg}" />
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="{StaticResource MarginDivider}" />
                            <DockPanel Margin="{StaticResource MarginSectionTitle}">
                                <TextBlock DockPanel.Dock="Left" Text="Verify" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                <Border x:Name="PreflightStateBadge" DockPanel.Dock="Right" Background="{StaticResource WarnSoftBrush}" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource PaddingPill}">
                                    <TextBlock x:Name="PreflightStateText" Text="Not Run" Foreground="{StaticResource WarnBrush}" FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold" />
                                </Border>
                            </DockPanel>
                            <TextBlock x:Name="PreflightSummaryText" Margin="{StaticResource MarginSectionTitle}" Text="Verify connection and remote environment." Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeMd}" TextWrapping="Wrap" />
                            <Button x:Name="PreflightButton" Content="Verify Connection" MinWidth="0" Padding="{StaticResource PaddingMd}" FontSize="{StaticResource FontSizeMd}" />
                            <Expander IsExpanded="False" Style="{StaticResource SectionExpanderStyle}" Margin="{StaticResource MarginGapMd}">
                                <Expander.Header>
                                    <TextBlock Text="Details" FontSize="{StaticResource FontSizeLg}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                </Expander.Header>
                                <ListBox x:Name="PreflightListBox" Margin="{StaticResource MarginGapSm}" MaxHeight="160" BorderThickness="0" Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}" ItemTemplate="{StaticResource PreflightItemTemplate}" />
                            </Expander>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <GridSplitter x:Name="SettingsSplitter" Grid.Column="1" Width="4" Background="#2c3038" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="3,0" Visibility="Collapsed" />

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource StatusCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" MaxHeight="200" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Target" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="{StaticResource MarginSectionTitle}" />
                                <TreeView x:Name="TargetTreeView" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" FontFamily="{StaticResource FontMono}" Padding="0" />
                                <StackPanel Grid.Row="2" Margin="{StaticResource MarginGapSm}">
                                    <TextBlock Text="Or enter manually:" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginSectionTitle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                            <TextBlock Text="Site" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" />
                                            <TextBox x:Name="SiteTextBox" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                            <TextBlock Text="Host" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" />
                                            <TextBox x:Name="HostTextBox" />
                                        </StackPanel>
                                    </Grid>
                                    <Expander IsExpanded="False" Style="{StaticResource SectionExpanderStyle}">
                                        <Expander.Header>
                                            <TextBlock Text="Advanced" FontSize="{StaticResource FontSizeLg}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                        </Expander.Header>
                                        <StackPanel Margin="{StaticResource MarginGapSm}">
                                            <TextBlock Text="Extra Args" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeMd}" />
                                            <TextBox x:Name="ExtraArgsTextBox" TextWrapping="Wrap" AcceptsReturn="True" Height="50" VerticalScrollBarVisibility="Auto" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource StatusCardStyle}" Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Action" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="{StaticResource MarginSectionTitle}" />

                                <TreeView x:Name="ActionTreeView" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" FontFamily="{StaticResource FontMono}" Padding="0" />


                                <WrapPanel Grid.Row="2" Margin="{StaticResource MarginGapMd}">
                                    <Button x:Name="RunButton" Content="Run" />
                                    <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <GridSplitter x:Name="ConsoleSplitter" Grid.Column="3" Width="4" Background="#2c3038" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="3,0" Visibility="Collapsed" />

                    <Grid x:Name="ConsolePane" Grid.Column="4" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8,8,0,0" Padding="{StaticResource PaddingLg}">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Text="Console" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeMd}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock x:Name="ConsoleHintText" DockPanel.Dock="Left" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginInlineMd}" VerticalAlignment="Center" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="CopyOutputButton" Content="Copy" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingPill}" FontSize="{StaticResource FontSizeSm}" />
                                        <Button x:Name="ExportOutputButton" Content="Export" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingPill}" FontSize="{StaticResource FontSizeSm}" />
                                        <Button x:Name="ConsoleToggleButton" Content="✕" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="{StaticResource PaddingPill}" FontSize="{StaticResource FontSizeSm}" ToolTip="Collapse console" />
                                    </StackPanel>
                                </DockPanel>
                                <TextBox x:Name="CommandPreviewTextBox" IsReadOnly="True" TextWrapping="NoWrap" Background="#0d1015" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="{StaticResource MarginGapSm}" Padding="{StaticResource PaddingSm}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeMd}" Foreground="{StaticResource TextBrush}" />
                            </StackPanel>
                        </Border>

                        <TextBox x:Name="ConsoleTextBox" Grid.Row="1" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeLg}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#0d1015" Foreground="#d8dce2" CaretBrush="#d8dce2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1" />

                        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" Padding="{StaticResource PaddingMd}">
                            <Expander IsExpanded="False" Style="{StaticResource SectionExpanderStyle}" Margin="0">
                                <Expander.Header>
                                    <TextBlock Text="Detected Paths" FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                </Expander.Header>
                                <ListBox x:Name="DetectedPathsListBox" Margin="{StaticResource MarginGapSm}" MaxHeight="100" BorderThickness="0" Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}" ItemTemplate="{StaticResource PathItemTemplate}" />
                            </Expander>
                        </Border>
                    </Grid>
                </Grid>

            <Border Grid.Row="2" Background="#0d1015" BorderBrush="#22262d" BorderThickness="0,1,0,0" Padding="{StaticResource PaddingBar}">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ConnectionInfoText" Grid.Column="0" Text="not connected" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource FontMono}" FontSize="{StaticResource FontSizeMd}" VerticalAlignment="Center" />
                    <Border Grid.Column="1" Width="1" Height="14" Background="#2c3038" Margin="10,0" VerticalAlignment="Center" />
                    <Border x:Name="RunStateBorder" Grid.Column="2" Background="#1e2228" CornerRadius="{StaticResource RadiusLg}" Padding="{StaticResource PaddingPill}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="RunStateText" Text="Idle" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeSm}" FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock x:Name="RunMetaText" Margin="{StaticResource MarginInlineSm}" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="StatusTextBlock" Grid.Column="3" Text="Ready." TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeMd}" VerticalAlignment="Center" Margin="{StaticResource MarginStatusItem}" />
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MarginStatusItem}">
                        <TextBlock Text="Exit:" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginLabelValue}" />
                        <TextBlock x:Name="ExitCodeTextBlock" Text="-" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MarginStatusItem}">
                        <TextBlock Text="Duration:" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeSm}" Margin="{StaticResource MarginLabelValue}" />
                        <TextBlock x:Name="DurationTextBlock" Text="-" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource FontSizeSm}" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
