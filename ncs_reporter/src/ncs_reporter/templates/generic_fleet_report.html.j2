<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% set view = generic_fleet_view | default({}) %}
    {% set meta = view.get('meta', {}) %}
    {% set nav = view.get('nav', {}) %}
    {% set hosts = view.get('hosts', []) %}
    {% set active_alerts = view.get('active_alerts', []) %}
    {% set crit_hosts  = hosts | selectattr('critical_count', 'gt', 0) | list | length %}
    {% set warn_hosts  = hosts | selectattr('warning_count',  'gt', 0) | list | length %}
    {% set ok_hosts    = hosts | selectattr('health', 'eq', 'OK') | list | length %}
    <title>{{ meta.get('display_name', 'Fleet') }} — Fleet Report</title>
    <style>{{ _minified_css }}</style>
</head>
<body>
<div class="page-wrap">

    {% from '_breadcrumb_bar.html.j2' import breadcrumb_bar %}
    {{ breadcrumb_bar(nav.get('breadcrumbs', [])) }}

    <div class="page-header">
        <div>
            <h1>{{ meta.get('display_name', 'Fleet') }} — Fleet Report</h1>
            <span class="page-subtitle">Platform: {{ meta.get('platform', '') | upper }} &nbsp;&middot;&nbsp; {{ meta.get('total_hosts', 0) }} hosts</span>
        </div>
        <div class="right">
            {{ meta.get('report_date', report_date | default('')) }}
        </div>
    </div>

    <div class="toc">
        <div class="toc-left">
            {% if active_alerts %}<a href="#alerts">Active Alerts</a>{% endif %}
            <a href="#hosts">Host Status</a>
        </div>
    </div>

    {# --- Active alerts widget --- #}
    {% if alert_groups %}
    <div class="widget widget-alert" id="alerts">
        <div class="widget-titlebar">
            <span class="widget-title">Active Alerts &mdash; {{ active_alerts | length }}{% if crit_count > 0 %} ({{ crit_count }} CRITICAL{% if warn_count > 0 %}, {{ warn_count }} WARNING{% endif %}){% endif %}</span>
            <button class="widget-toggle" aria-expanded="true" aria-label="Collapse Active Alerts"></button>
        </div>
        <div class="widget-body widget-table-view">
        <table>
            <thead>
                <tr><th class="th-severity">Severity</th><th class="th-category">Category</th><th>Message</th></tr>
            </thead>
            <tbody>
            {% for group in alert_groups %}
                {% set gid = loop.index %}
                <tr class="group-hdr" data-group="{{ gid }}">
                    <td colspan="3">
                        <span class="group-toggle"></span>
                        <strong><a href="{{ group.node_report }}">{{ group.host }}</a></strong>
                    </td>
                </tr>
                {% for alert in group.alerts %}
                {% set has_items = alert.get('affected_items', []) | length > 0 %}
                {% set fleet_alert_id = 'fleet-alert-' ~ gid ~ '-' ~ loop.index %}
                <tr class="group-row {{ 'alert-crit' if alert.severity == 'CRITICAL' else 'alert-warn' if alert.severity == 'WARNING' else '' }} {{ 'alert-expandable' if has_items else '' }}" data-group="{{ gid }}" {% if has_items %}data-alert-detail="{{ fleet_alert_id }}"{% endif %}>
                    <td class="{{ 'sv-critical' if alert.severity == 'CRITICAL' else 'sv-warning' if alert.severity == 'WARNING' else 'sv-info' }} severity-cell">{{ alert.severity }}</td>
                    <td class="nowrap subtle-text strong-text alert-category">{{ alert.get('category', '') }}</td>
                    <td>
                        {{ alert.get('message', '') }}
                        {% if has_items %}<span class="alert-expand-hint">({{ alert.affected_items | length }} item{{ 's' if alert.affected_items | length != 1 else '' }})</span>{% endif %}
                        {% if alert.get('detail') %}
                        <div class="alert-details">
                            {% for dk, dv in alert.detail.items() %}
                            <span><strong>{{ dk }}:</strong> {{ dv }}</span>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </td>
                </tr>
                {% if has_items %}
                {% set items = alert.affected_items %}
                {% set display_items = items[:50] %}
                {% set remaining = items | length - 50 %}
                {% set sample = display_items[0] if display_items else {} %}
                {% set col_keys = sample.keys() | list if sample is mapping else [] %}
                {% set skip_keys = ['tags', 'attributes', 'moid', 'uuid', 'instance_uuid', 'datastore_url', 'backup_info'] %}
                {% set display_cols = [] %}
                {% for k in col_keys %}{% if k not in skip_keys and not k.startswith('_') %}{% if display_cols.append(k) %}{% endif %}{% endif %}{% endfor %}
                {% set display_cols = display_cols[:8] %}
                <tr class="alert-detail-row group-row" id="{{ fleet_alert_id }}" data-group="{{ gid }}" style="display: none;">
                    <td colspan="3">
                        <div class="alert-affected-items">
                            {% if display_cols %}
                            <table class="affected-items-table">
                                <thead><tr>{% for col in display_cols %}<th>{{ col | replace('_', ' ') | title }}</th>{% endfor %}</tr></thead>
                                <tbody>
                                {% for item in display_items %}
                                    <tr>{% for col in display_cols %}{% set val = item[col] if item is mapping else item %}<td>{% if val is mapping or (val is iterable and val is not string) %}<span class="subtle-text">{{ val | length }} items</span>{% else %}{{ val }}{% endif %}</td>{% endfor %}</tr>
                                {% endfor %}
                                </tbody>
                            </table>
                            {% if remaining > 0 %}<div class="affected-items-overflow">&hellip;and {{ remaining }} more item{{ 's' if remaining != 1 else '' }}</div>{% endif %}
                            {% else %}
                            <ul class="affected-items-list">{% for item in display_items %}<li>{{ item }}</li>{% endfor %}</ul>
                            {% if remaining > 0 %}<div class="affected-items-overflow">&hellip;and {{ remaining }} more</div>{% endif %}
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% endif %}
                {% endfor %}
            {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
    {% endif %}

    <div class="widget" id="hosts">
        <div class="widget-titlebar">
            <span class="widget-title">Host Status</span>
            <button class="widget-toggle" aria-expanded="true" aria-label="Collapse Host Status"></button>
        </div>
        <div class="widget-body widget-table-view">
        <table>
            <thead>
                <tr>
                    <th class="sortable">Hostname</th>
                    <th class="th-health sortable">Health</th>
                    {% for col in generic_fleet_view.get('fleet_columns', []) %}
                        <th class="sortable" style="{% if col.get('width') %}width:{{ col.width }};{% endif %}">{{ col.label }}</th>
                    {% endfor %}
                    {# Keep alert counts as optional default if no columns defined? No, stay 100% schema. #}
                </tr>
            </thead>
            <tbody>
            {% for host in hosts %}
                <tr>
                    <td><a href="{{ host.node_report }}" class="link-strong">{{ host.hostname }}</a></td>
                    <td>
                        {% if host.health == 'OK' %}<span class="sv-ok">OK</span>
                        {% elif host.health == 'WARNING' %}<span class="sv-warning">WARNING</span>
                        {% elif host.health == 'CRITICAL' %}<span class="sv-critical">CRITICAL</span>
                        {% else %}{{ host.health }}{% endif %}
                    </td>
                    {% for col in generic_fleet_view.get('fleet_columns', []) %}
                        <td>{{ host.get('col_' ~ col.field, '') }}</td>
                    {% endfor %}
                </tr>
            {% else %}
                <tr><td colspan="{{ 2 + generic_fleet_view.get('fleet_columns', []) | length }}" class="subtle-text">No hosts found.</td></tr>
            {% endfor %}
            </tbody>
        </table>
        </div>
    </div>



</div>
<script>{{ _minified_js }}</script>
</body>
</html>
