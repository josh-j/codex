{% macro render_badge(value) %}
{% set v = (value | string) | lower %}
{% if v in ('poweredon', 'toolsok', 'toolsrunning', 'green', 'ok', 'up', 'running', 'connected', 'healthy', 'true') %}
    <span class="sv-ok" title="{{ value }}"><span class="status-icon status-icon-ok"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('red', 'critical', 'down', 'error', 'failed', 'false') %}
    <span class="sv-critical" title="{{ value }}"><span class="status-icon status-icon-crit"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('yellow', 'warning', 'degraded') %}
    <span class="sv-warning" title="{{ value }}"><span class="status-icon status-icon-warn"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('gray', 'grey', 'unknown') %}
    <span class="sv-info" title="{{ value }}"><span class="status-icon status-icon-off"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('poweredoff', 'suspended') %}
    <span class="sv-off" title="{{ value }}"><span class="status-icon status-icon-off"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('toolsnotinstalled', 'toolsnotrunning', 'toolsold') %}
    <span class="sv-warning" title="{{ value }}"><span class="status-icon status-icon-warn"></span><span class="badge-text-print">{{ value }}</span></span>
{% else %}
    {{ value }}
{% endif %}
{% endmacro %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% set view = generic_node_view | default({}) %}
    {% set meta = view.get('meta', {}) %}
    {% set nav = view.get('nav', {}) %}
    {% set health = view.get('health', 'UNKNOWN') %}
    {% set summary = view.get('summary', {}) %}
    {% set alerts = view.get('alerts', []) %}
    {% set widgets = view.get('widgets', []) %}
    {% set crit = summary.get('critical_count', 0) %}
    {% set warn = summary.get('warning_count', 0) %}
    <title>{{ meta.get('display_name', 'Report') }} — Node Report — {{ meta.get('host', 'host') }}</title>
    <style>{{ _minified_css }}</style>
</head>
<body>
<div class="page-wrap">

    {# Breadcrumb navigation tree #}
    {% if nav.get('site_report') or nav.get('fleet_report') %}
    <div class="breadcrumb">
        {% if nav.get('site_report') %}
        <a href="{{ nav.site_report }}" title="Go to Site Dashboard"><span class="site-home">&#x2302;</span>Site Dashboard</a><span class="sep">&rsaquo;</span>
        {% endif %}
        
        {% if nav.get('tree_fleets') %}
        <div class="nav-tree">
            <a href="{{ nav.fleet_report or '#' }}" class="tree-label">{{ (nav.get('fleet_label') or 'Fleet') | replace(' Fleet', '') }} Fleet</a>
            <span class="tree-trigger">&#9660;</span>
            <div class="nav-dropdown">
                <div class="dropdown-group">Fleets</div>
                {% for f in nav.tree_fleets %}
                <a href="{{ f.report }}" class="{{ 'active' if f.name in (nav.get('fleet_label') or '') else '' }} {{ 'stig-link' if f.name == 'STIG' else '' }}">
                    {{ f.name }} Fleet
                </a>
                {% endfor %}
            </div>
        </div>
        <span class="sep">&rsaquo;</span>
        {% elif nav.get('fleet_report') %}
        <a href="{{ nav.fleet_report }}">{{ nav.get('fleet_label', 'Fleet Report') }}</a><span class="sep">&rsaquo;</span>
        {% endif %}

        {% if nav.get('tree_siblings') %}
        <div class="nav-tree">
            <span class="tree-label">{{ meta.get('host') }}</span>
            <span class="tree-trigger">&#9660;</span>
            <div class="nav-dropdown nav-dropdown-scroll">
                <div class="dropdown-group">Hosts</div>
                {% for s in nav.tree_siblings %}
                <a href="{{ s.report }}" class="{{ 'active' if s.name == meta.get('host') else '' }}">{{ s.name }}</a>
                {% endfor %}
            </div>
        </div>
        {% if nav.history %}
        <span class="sep">&rsaquo;</span>
        <div class="nav-tree">
            <span class="tree-label">History</span>
            <span class="tree-trigger">&#9660;</span>
            <div class="nav-dropdown nav-dropdown-scroll">
                <div class="dropdown-group">Report Versions</div>
                {% for h in nav.history %}
                <a href="{{ h.url }}">{{ h.name }}</a>
                {% endfor %}
            </div>
        </div>
        {% endif %}
        {% else %}
        {{ meta.get('host', 'host') }}
        {% endif %}
        <div class="nav-search" data-root="{{ nav.site_report | replace('site_health_report.html', '') if nav.get('site_report') else './' }}">
            <input type="text" placeholder="Search hosts..." aria-label="Search hosts">
            <div class="search-results nav-dropdown"></div>
        </div>
    </div>
    {% endif %}

    <div class="page-header">
        <div>
            <h1>{{ meta.get('display_name', 'Report') }} &mdash; <code>{{ meta.get('host', 'host') }}</code></h1>
            <span class="page-subtitle">Platform: {{ meta.get('platform', '') | upper }}</span>
        </div>
        <div class="right">
            {% if health == 'OK' %}<span class="health-ok">OK</span>
            {% elif health == 'WARNING' %}<span class="health-warn">WARNING</span>
            {% elif health == 'CRITICAL' %}<span class="health-crit">CRITICAL</span>
            {% else %}<span class="health-unk">{{ health }}</span>{% endif %}
            <br>{{ meta.get('report_date', report_date | default('')) }}
        </div>
    </div>

    <div class="toc">
        <div class="toc-left">
            {% for widget in widgets %}
            <a href="#{{ widget.id }}">{{ widget.title }}</a>
            {% endfor %}
        </div>
    </div>

    <div class="widget-grid-container">
    {% for widget in widgets %}
        {% set w_width = widget.get('layout', {}).get('width', 'full') %}
        {% set flex_basis = '100%' %}
        {% if w_width == 'half' %}{% set flex_basis = 'calc(50% - 7px)' %}
        {% elif w_width == 'third' %}{% set flex_basis = 'calc(33.333% - 9.33px)' %}
        {% elif w_width == 'quarter' %}{% set flex_basis = 'calc(25% - 10.5px)' %}
        {% endif %}

        <div class="widget {{ 'widget-alert' if widget.type == 'alert_panel' else '' }}" id="{{ widget.id }}" style="flex: 1 1 {{ flex_basis }}; min-width: 300px; margin-bottom: 0;">
            <div class="widget-titlebar">
                {% if widget.type == 'alert_panel' %}
                <span class="widget-title">Active Alerts &mdash; {{ summary.get('total', 0) }}{% if crit > 0 %} ({{ crit }} CRITICAL{% if warn > 0 %}, {{ warn }} WARNING{% endif %}){% endif %}</span>
                {% else %}
                <span class="widget-title">{{ widget.title }}</span>
                {% endif %}
                <button class="widget-toggle" aria-expanded="true" aria-label="Collapse {{ widget.title }}"></button>
            </div>
            
            {% if widget.type == 'progress_bar' %}
            <div class="widget-body" style="padding: 16px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 12px; font-weight: 600;">
                    <span>{{ widget.label }}</span>
                    <span>{{ widget.percent }}%</span>
                </div>
                <div style="background: var(--line); border-radius: 4px; height: 8px; overflow: hidden;">
                    <div style="width: {{ widget.percent }}%; height: 100%; background: var(--{{ widget.color|default('brand') }}); border-radius: 4px; transition: width 0.3s ease;"></div>
                </div>
            </div>

            {% elif widget.type == 'markdown' %}
            <div class="widget-body details-description" style="margin-bottom: 0; border: 1px solid var(--line); border-top: none; border-radius: 0 0 10px 10px;">
                {{ widget.content }}
            </div>

            {% elif widget.type == 'stat_cards' %}
            <div class="widget-body widget-body-padded">
            <div class="stat-cards-row">
                {% for card in widget.get('cards', []) %}
                <div class="stat-card stat-card-{{ card.color | default('blue') }}">
                    <div class="stat-card-value">{{ card.value }}</div>
                    <div class="stat-card-label">{{ card.label }}</div>
                </div>
                {% endfor %}
            </div>
            </div>

            {% elif widget.type == 'bar_chart' %}
            <div class="widget-body widget-body-padded">
            {% if widget.get('bars', []) %}
            <div class="bar-chart">
                {% for bar in widget.bars %}
                <div class="bar-chart-row">
                    <span class="bar-chart-label">{{ bar.label }}</span>
                    <div class="bar-chart-track">
                        <div class="bar-chart-fill bar-chart-{{ bar.color | default('blue') }}" style="width: {{ bar.width_pct }}%;"></div>
                    </div>
                    <span class="bar-chart-value">{{ bar.value | round(1) }}%</span>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="no-data">No data.</div>
            {% endif %}
            </div>

            {% elif widget.type == 'list' %}
            <div class="widget-body widget-body-padded">
            {% if widget.get('items', []) %}
                {% if widget.style == 'comma' %}
                <div class="list-widget-comma">{{ widget.items | join(', ') }}</div>
                {% elif widget.style == 'numbered' %}
                <ol class="list-widget">
                    {% for item in widget.items %}
                    <li>{{ item }}</li>
                    {% endfor %}
                </ol>
                {% else %}
                <ul class="list-widget">
                    {% for item in widget.items %}
                    <li>{{ item }}</li>
                    {% endfor %}
                </ul>
                {% endif %}
            {% else %}
            <div class="no-data">{{ widget.empty_text | default('None') }}</div>
            {% endif %}
            </div>

            {% else %}
            <div class="widget-body widget-table-view">

            {% if widget.type == 'alert_panel' %}
            {% if alerts %}
            <table>
                <thead>
                    <tr><th class="th-severity">Severity</th><th class="th-category">Category</th><th>Message</th></tr>
                </thead>
                <tbody>
                {% for alert in alerts %}
                    <tr class="{{ 'alert-crit' if alert.severity == 'CRITICAL' else 'alert-warn' if alert.severity == 'WARNING' else '' }}">
                        <td class="{{ 'sv-critical' if alert.severity == 'CRITICAL' else 'sv-warning' if alert.severity == 'WARNING' else 'sv-info' }} nowrap">{{ alert.severity }}</td>
                        <td class="nowrap subtle-text strong-text alert-category">{{ alert.get('category', '') }}</td>
                        <td>
                            {{ alert.get('message', '') }}
                            {% if alert.get('detail') %}
                            <div class="alert-details">
                                {% for dk, dv in alert.detail.items() %}
                                <span><strong>{{ dk }}:</strong> {{ dv }}</span>
                                {% endfor %}
                            </div>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No active alerts.</div>
            {% endif %}

            {% elif widget.type == 'key_value' %}
            {% if widget.get('rows', []) %}
            <table class="kv">
                <tbody>
                {% for row in widget.rows %}
                    <tr><td>{{ row.label }}</td><td>{% if row.badge %}{{ render_badge(row.value) }}{% else %}{{ row.value }}{% endif %}</td></tr>
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No data.</div>
            {% endif %}

            {% elif widget.type == 'table' %}
            {% if widget.get('rows', []) %}
            <table>
                <thead>
                    <tr>
                    {% for col in widget.get('columns', []) %}
                        <th class="sortable">{{ col.label }}</th>
                    {% endfor %}
                    </tr>
                </thead>
                <tbody>
                {% for row in widget.rows %}
                    <tr class="row-interactive">
                    {% for cell in row %}
                        <td class="{{ cell.css_class | default('') }}">
                        {% if cell.link %}<a href="{{ cell.link }}" class="link-strong">{% endif %}
                        {% if cell.badge %}
                            {{ render_badge(cell.value) }}
                        {% else %}
                            {{ cell.value }}
                        {% endif %}
                        {% if cell.link %}</a>{% endif %}
                        </td>
                    {% endfor %}
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No rows.</div>
            {% endif %}

            {% elif widget.type == 'grouped_table' %}
            {% if widget.get('groups', {}) %}
            <table>
                <thead>
                    <tr>
                    {% for col in widget.get('columns', []) %}
                        <th class="sortable">{{ col.label }}</th>
                    {% endfor %}
                    </tr>
                </thead>
                <tbody>
                {% for group_name, group_rows in widget.groups.items() %}
                    {% set grp_id = "grp-" ~ widget.id ~ "-" ~ loop.index %}
                    <tr class="group-hdr" data-group="{{ grp_id }}">
                        <td colspan="{{ widget.columns | length }}">
                            <span class="group-toggle"></span>
                            <strong>{{ group_name }}</strong>
                            <span class="subtle-text">({{ group_rows | length }})</span>
                        </td>
                    </tr>
                    {% for row in group_rows %}
                    <tr class="group-row row-interactive" data-group="{{ grp_id }}">
                    {% for cell in row %}
                        <td class="{{ cell.css_class | default('') }}">
                        {% if cell.link %}<a href="{{ cell.link }}" class="link-strong">{% endif %}
                        {% if cell.badge %}
                            {{ render_badge(cell.value) }}
                        {% else %}
                            {{ cell.value }}
                        {% endif %}
                        {% if cell.link %}</a>{% endif %}
                        </td>
                    {% endfor %}
                    </tr>
                    {% endfor %}
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No rows.</div>
            {% endif %}

            {% endif %}
            </div>
            {% endif %}
        </div>
    {% endfor %}
    </div>

</div>
<script>{{ _minified_js }}</script>
</body>
</html>
