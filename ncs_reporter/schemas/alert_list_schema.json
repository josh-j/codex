{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NCS Reporter Alert List",
  "description": "A list of alert rules, included via $include in main config files.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/AlertRule"
  },
  "$defs": {
    "ActionSpec": {
      "additionalProperties": false,
      "description": "Structured alert action: ansible-playbook invocation or raw shell command.",
      "properties": {
        "playbook": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Playbook"
        },
        "extra_vars": {
          "additionalProperties": true,
          "title": "Extra Vars",
          "type": "object"
        },
        "timeout": {
          "default": 120,
          "title": "Timeout",
          "type": "integer"
        },
        "command": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Command"
        }
      },
      "title": "ActionSpec",
      "type": "object"
    },
    "AlertRule": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "category": {
          "title": "Category",
          "type": "string"
        },
        "severity": {
          "default": "WARNING",
          "enum": [
            "CRITICAL",
            "WARNING",
            "INFO"
          ],
          "title": "Severity",
          "type": "string"
        },
        "when": {
          "title": "When",
          "type": "string"
        },
        "action": {
          "anyOf": [
            {
              "$ref": "#/$defs/ActionSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "cooldown": {
          "default": "7d",
          "title": "Cooldown",
          "type": "string"
        },
        "msg": {
          "title": "Msg",
          "type": "string"
        },
        "suppress_if": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Suppress If"
        }
      },
      "required": [
        "id",
        "category",
        "when",
        "msg"
      ],
      "title": "AlertRule",
      "type": "object"
    }
  }
}
