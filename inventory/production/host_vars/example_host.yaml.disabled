# Per-host variable overrides.
#
# To use: copy this file and rename it to match the inventory hostname, e.g.:
#   cp example_host.yaml.disabled ubuntu-srv01.site1.yourdomain.mil.yaml
#
# Any variable set here overrides group_vars for this specific host.

