# {{ ansible_managed }}
# OpenSSH Server configuration — managed by Ansible (internal.windows.windows)

# --- Authentication ---
GSSAPIAuthentication {{ 'yes' if windows_openssh_allow_gssapi else 'no' }}
GSSAPICleanupCredentials yes
PasswordAuthentication {{ 'yes' if windows_openssh_allow_password else 'no' }}
PubkeyAuthentication {{ 'yes' if windows_openssh_allow_pubkey else 'no' }}
PermitRootLogin no
MaxAuthTries {{ windows_openssh_max_auth_tries }}

{% if windows_openssh_allow_groups | length > 0 %}
# --- Access Control ---
AllowGroups {{ windows_openssh_allow_groups | join(' ') }}

{% endif %}
# --- Session ---
ClientAliveInterval {{ windows_openssh_client_alive_interval }}
ClientAliveCountMax {{ windows_openssh_client_alive_count_max }}

# --- Subsystems ---
Subsystem sftp sftp-server.exe

{% if windows_openssh_allow_pubkey %}
# --- Admin Authorized Keys (Windows OpenSSH special path) ---
Match Group administrators
    AuthorizedKeysFile __PROGRAMDATA__/ssh/administrators_authorized_keys
{% endif %}
