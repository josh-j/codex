{# Generic tree-tier report page. Drives every node in the hierarchical
   report tree (inventory root, intermediate tiers, leaf host pages).
   Shape of `tree_node_view`:
     meta      : {tier, slug, title, display_name, report_date, generated_at}
     health    : "OK" | "WARNING" | "CRITICAL"
     summary   : {total, critical_count, warning_count, info_count}
     alerts    : [{severity, category, message, detail, affected_items}]
     widgets   : [{slug, name, type, ...}]  (see _render_widget)
     nav.breadcrumbs : [{text, href?}]   (last entry has href=None)
     nav.children    : [{title, tier, url, child_count}]
#}
{% macro render_badge(value) %}
{% set v = (value | string) | lower %}
{% if v in ('poweredon', 'toolsok', 'toolsrunning', 'green', 'ok', 'up', 'running', 'connected', 'healthy', 'true') %}
    <span class="sv-ok" title="{{ value }}"><span class="status-icon status-icon-ok"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('red', 'critical', 'down', 'error', 'failed', 'false') %}
    <span class="sv-critical" title="{{ value }}"><span class="status-icon status-icon-crit"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('yellow', 'warning', 'degraded') %}
    <span class="sv-warning" title="{{ value }}"><span class="status-icon status-icon-warn"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('gray', 'grey', 'unknown') %}
    <span class="sv-info" title="{{ value }}"><span class="status-icon status-icon-off"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('poweredoff', 'suspended') %}
    <span class="sv-off" title="{{ value }}"><span class="status-icon status-icon-off"></span><span class="badge-text-print">{{ value }}</span></span>
{% else %}
    {{ value }}
{% endif %}
{% endmacro %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% set view = tree_node_view | default({}) %}
    {% set meta = view.get('meta', {}) %}
    {% set nav = view.get('nav', {}) %}
    {% set summary = view.get('summary', {}) %}
    {% set alerts = view.get('alerts', []) %}
    {% set available_alerts = view.get('available_alerts', []) %}
    {% set widgets = view.get('widgets', []) %}
    {% set children = nav.get('children', []) %}
    {% set health = view.get('health', 'UNKNOWN') %}
    {% set crit = summary.get('critical_count', 0) %}
    {% set warn = summary.get('warning_count', 0) %}
    <title>{{ meta.get('display_name', 'Report') }} — {{ meta.get('title', meta.get('slug', '')) }}</title>
    <style>{{ _minified_css }}</style>
</head>
<body>
<div class="page-wrap">

    {# Breadcrumb trail — typed crumbs (link/label/dropdown/search) shared
       with the site dashboard via ``_breadcrumb_bar.html.j2``. #}
    {% from '_breadcrumb_bar.html.j2' import breadcrumb_bar %}
    {% from '_log_tail.html.j2' import log_tail_body %}
    {{ breadcrumb_bar(nav.get('breadcrumbs', [])) }}

    <div class="page-header page-header-standalone">
        <div>
            <h1>{{ meta.get('display_name', 'Report') }} &mdash; <code>{{ meta.get('title', meta.get('slug', '')) }}</code></h1>
            <span class="page-subtitle">Tier: {{ meta.get('tier', '') | upper }}</span>
        </div>
        <div class="right">
            {% if health == 'OK' %}<span class="health-ok">OK</span>
            {% elif health == 'WARNING' %}<span class="health-warn">WARNING</span>
            {% elif health == 'CRITICAL' %}<span class="health-crit">CRITICAL</span>
            {% else %}<span class="health-unk">{{ health }}</span>{% endif %}
            {% set _date = meta.get('report_date') or report_date | default('') %}
            {% if _date %}<br>{{ _date }}{% endif %}
        </div>
    </div>

    {# Page reading flow: alerts → child navigation → detail widgets.
       Alerts and details are split out of the widget loop so children
       can sit between them. #}
    {% set _alert_widgets = widgets | selectattr('type', 'equalto', 'alert_panel') | list %}
    {% set _other_widgets = widgets | rejectattr('type', 'equalto', 'alert_panel') | list %}

    {% if alerts %}
    {% set _alert_sev_class = 'severity-crit' if crit > 0 else 'severity-warn' if warn > 0 else 'severity-info' %}
    {% for widget in _alert_widgets %}
    <div class="widget widget-alert {{ _alert_sev_class }}" id="{{ widget.slug }}">
        <div class="widget-titlebar">
            <span class="widget-title">
                NCS Alerts &mdash; {{ summary.get('total', 0) }}{% if crit > 0 %} ({{ crit }} CRITICAL{% if warn > 0 %}, {{ warn }} WARNING{% endif %}){% endif %}
                {% if available_alerts %}
                <span class="alert-rules-help" tabindex="0" aria-haspopup="true">
                    <span class="alert-rules-help-trigger" title="Show all available alert rules" aria-label="Show all available alert rules">?</span>
                    <div class="alert-rules-help-popover" role="tooltip">
                        <div class="alert-rules-help-title">Available alert rules ({{ available_alerts | length }})</div>
                        <table class="alert-rules-help-table">
                            <thead>
                                <tr><th>Severity</th><th>Category</th><th>Message</th></tr>
                            </thead>
                            <tbody>
                            {% for r in available_alerts %}
                                <tr>
                                    <td class="sv-{{ r.severity | lower }}">{{ r.severity }}</td>
                                    <td class="subtle-text">{{ r.category }}</td>
                                    <td>{{ r.message }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </span>
                {% endif %}
            </span>
            <button class="widget-toggle" aria-expanded="true" aria-label="Collapse NCS Alerts"></button>
        </div>
        <div class="widget-body">
            <table>
                <thead><tr><th class="th-severity">Severity</th><th class="th-category">Category</th><th>Message</th></tr></thead>
                <tbody>
                {% for a in alerts %}
                    <tr class="alert-{{ a.severity | lower }}">
                        <td class="severity-cell sv-{{ a.severity | lower }}">{{ a.severity }}</td>
                        <td class="alert-category subtle-text">{{ a.category }}</td>
                        <td>{% if a.origin %}<strong>{{ a.origin }}</strong> &mdash; {% endif %}{{ a.message }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endfor %}
    {% endif %}

    {# Children-of-this-node navigation block — only shown when the node has descendants #}

    <div class="widget-grid-container">
    {% for widget in _other_widgets %}
        {% set w_width = widget.get('layout', {}).get('width', 'full') %}
        {% set flex_basis = '100%' %}
        {% if w_width == 'half' %}{% set flex_basis = 'calc(50% - 7px)' %}
        {% elif w_width == 'third' %}{% set flex_basis = 'calc(33.333% - 9.33px)' %}
        {% elif w_width == 'quarter' %}{% set flex_basis = 'calc(25% - 10.5px)' %}
        {% endif %}

        {% set _w_alert_sev = ('severity-crit' if crit > 0 else 'severity-warn' if warn > 0 else 'severity-info') if widget.type == 'alert_panel' else '' %}
        <div class="widget {{ 'widget-alert ' + _w_alert_sev if widget.type == 'alert_panel' else '' }}" id="{{ widget.slug }}" style="flex: 1 1 {{ flex_basis }}; min-width: 300px; margin-bottom: 0;">
            <div class="widget-titlebar">
                {% if widget.type == 'alert_panel' %}
                <span class="widget-title">NCS Alerts &mdash; {{ summary.get('total', 0) }}{% if crit > 0 %} ({{ crit }} CRITICAL{% if warn > 0 %}, {{ warn }} WARNING{% endif %}){% endif %}</span>
                {% else %}
                <span class="widget-title">{{ widget.name }}</span>
                {% endif %}
                <button class="widget-toggle" aria-expanded="true" aria-label="Collapse {{ widget.name }}"></button>
            </div>

            {% if widget.type == 'stat_cards' %}
            <div class="widget-body widget-body-padded">
                <div class="stat-cards-row">
                    {% for card in widget.get('cards', []) %}
                    <div class="stat-card stat-card-{{ card.color | default('blue') }}">
                        <div class="stat-card-value">{{ card.value }}</div>
                        <div class="stat-card-label">{{ card.name }}</div>
                    </div>
                    {% endfor %}
                </div>
            </div>

            {% elif widget.type == 'log_tail' %}
            {{ log_tail_body(widget) }}

            {% else %}
            <div class="widget-body widget-table-view">

            {% if widget.type == 'alert_panel' %}
            {% if alerts %}
            <table>
                <thead><tr><th class="th-severity">Severity</th><th class="th-category">Category</th><th>Message</th></tr></thead>
                <tbody>
                {% for alert in alerts %}
                    <tr class="{{ 'alert-crit' if alert.severity == 'CRITICAL' else 'alert-warn' if alert.severity == 'WARNING' else '' }}">
                        <td class="{{ 'sv-critical' if alert.severity == 'CRITICAL' else 'sv-warning' if alert.severity == 'WARNING' else 'sv-info' }} nowrap">{{ alert.severity }}</td>
                        <td class="nowrap subtle-text strong-text alert-category">{{ alert.get('category', '') }}</td>
                        <td>{{ alert.get('message', '') }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No active alerts.</div>
            {% endif %}

            {% elif widget.type == 'key_value' %}
            {% if widget.get('rows', []) %}
            <table class="kv">
                <tbody>
                {% for row in widget.rows %}
                    <tr><td>{{ row.name }}</td><td>{% if row.as == 'status-badge' %}{{ render_badge(row.value) }}{% else %}{{ row.value }}{% endif %}</td></tr>
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No data.</div>
            {% endif %}

            {% elif widget.type == 'table' %}
            {% if widget.get('rows', []) %}
            <table>
                <thead>
                    <tr>{% for col in widget.get('columns', []) %}<th class="sortable">{{ col.name }}</th>{% endfor %}</tr>
                </thead>
                <tbody>
                {% for row in widget.rows %}
                    <tr class="row-interactive">
                    {% for cell in row %}
                        <td class="{{ cell.css_class | default('') }}">
                        {% if cell.link %}<a href="{{ cell.link }}" class="link-strong">{% endif %}
                        {% if cell.as == 'status-badge' %}{{ render_badge(cell.value) }}{% else %}{{ cell.value }}{% endif %}
                        {% if cell.link %}</a>{% endif %}
                        </td>
                    {% endfor %}
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No rows.</div>
            {% endif %}

            {% elif widget.type == 'grouped_table' %}
            {% if widget.get('groups', {}) %}
            <table>
                <thead>
                    <tr>{% for col in widget.get('columns', []) %}<th class="sortable">{{ col.name }}</th>{% endfor %}</tr>
                </thead>
                <tbody>
                {% for group_name, group_rows in widget.groups.items() %}
                    {% set grp_id = "grp-" ~ widget.slug ~ "-" ~ loop.index %}
                    <tr class="group-hdr" data-group="{{ grp_id }}">
                        <td colspan="{{ widget.columns | length }}">
                            <span class="group-toggle"></span>
                            <strong>{{ group_name }}</strong>
                            <span class="subtle-text">({{ group_rows | length }})</span>
                        </td>
                    </tr>
                    {% for row in group_rows %}
                    <tr class="group-row row-interactive" data-group="{{ grp_id }}">
                    {% for cell in row %}
                        <td class="{{ cell.css_class | default('') }}">
                        {% if cell.link %}<a href="{{ cell.link }}" class="link-strong">{% endif %}
                        {% if cell.as == 'status-badge' %}{{ render_badge(cell.value) }}{% else %}{{ cell.value }}{% endif %}
                        {% if cell.link %}</a>{% endif %}
                        </td>
                    {% endfor %}
                    </tr>
                    {% endfor %}
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No rows.</div>
            {% endif %}

            {% elif widget.type == 'inventory' %}
            {% if widget.get('sections', []) or widget.get('cards', []) %}
            {% if widget.get('cards', []) %}
            <div class="inventory-footprint">
            {% for card in widget.cards %}
                <span class="inventory-footprint-pair">
                    <span class="inventory-footprint-pair-value{% if card.color and card.color != 'auto' %} stat-card-{{ card.color }}{% endif %}">{{ card.value }}</span>
                    <span class="inventory-footprint-pair-label">{{ card.name }}</span>
                </span>
            {% endfor %}
            </div>
            {% endif %}
            <div class="widget-body widget-subgroup inventory-subgroup">
            {% if widget.get('sections', []) %}
            {% for section in widget.sections %}
                <div class="widget">
                    <div class="widget-titlebar">
                        <span class="widget-title">{{ section.name }} <span class="widget-title-meta">({{ section.row_count }})</span></span>
                        <button class="widget-toggle" aria-expanded="true" aria-label="Collapse {{ section.name }}"></button>
                    </div>
                    <div class="widget-body widget-table-view">
                        <table>
                            <thead>
                                <tr>{% for col in section.columns %}<th class="sortable">{{ col.name }}</th>{% endfor %}</tr>
                            </thead>
                            <tbody>
                            {% for row in section.rows %}
                                <tr class="row-interactive">
                                {% for cell in row %}
                                    <td class="{{ cell.css_class | default('') }}">
                                    {% if cell.link %}<a href="{{ cell.link }}" class="link-strong">{% endif %}
                                    {% if cell.as == 'status-badge' %}
                                        {{ render_badge(cell.value) }}
                                    {% elif cell.as == 'severity-tally' %}
                                        {# info/warning/critical tally: three colored spans
                                           separated by slashes. Empty/zero buckets dim out. #}
                                        {% set _t = cell.value %}
                                        {% set _i = _t.get('info', 0) | int %}
                                        {% set _w = _t.get('warning', 0) | int %}
                                        {% set _c = _t.get('critical', 0) | int %}
                                        <span class="{{ 'sv-info' if _i else 'subtle-text' }}">{{ _i }}</span>
                                        <span class="subtle-text">/</span>
                                        <span class="{{ 'sv-warning' if _w else 'subtle-text' }}">{{ _w }}</span>
                                        <span class="subtle-text">/</span>
                                        <span class="{{ 'sv-critical' if _c else 'subtle-text' }}">{{ _c }}</span>
                                    {% else %}
                                        {{ cell.value }}
                                    {% endif %}
                                    {% if cell.link %}</a>{% endif %}
                                    </td>
                                {% endfor %}
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endfor %}
            {% endif %}
            </div>
            {% else %}
            <div class="no-data">No inventory rows.</div>
            {% endif %}

            {% endif %}
            </div>
            {% endif %}
        </div>
    {% endfor %}
    </div>

</div>
<script>{{ _minified_js }}</script>
</body>
</html>
