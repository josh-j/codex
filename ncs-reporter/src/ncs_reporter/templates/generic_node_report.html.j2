{% macro render_badge(value) %}
{% set v = (value | string) | lower %}
{% if v in ('poweredon', 'toolsok', 'toolsrunning', 'green', 'ok', 'up', 'running', 'connected', 'healthy', 'true') %}
    <span class="sv-ok" title="{{ value }}"><span class="status-icon status-icon-ok"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('red', 'critical', 'down', 'error', 'failed', 'false') %}
    <span class="sv-critical" title="{{ value }}"><span class="status-icon status-icon-crit"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('yellow', 'warning', 'degraded') %}
    <span class="sv-warning" title="{{ value }}"><span class="status-icon status-icon-warn"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('gray', 'grey', 'unknown') %}
    <span class="sv-info" title="{{ value }}"><span class="status-icon status-icon-off"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('poweredoff', 'suspended') %}
    <span class="sv-off" title="{{ value }}"><span class="status-icon status-icon-off"></span><span class="badge-text-print">{{ value }}</span></span>
{% elif v in ('toolsnotinstalled', 'toolsnotrunning', 'toolsold') %}
    <span class="sv-warning" title="{{ value }}"><span class="status-icon status-icon-warn"></span><span class="badge-text-print">{{ value }}</span></span>
{% else %}
    {{ value }}
{% endif %}
{% endmacro %}

{# ─── STIG finding row macro ──────────────────────────────────────────────── #}
{% macro render_finding_row(rule) %}
{% set rule_detail = rule.get('detail', {}) %}
{% set status_raw = rule.get('status', 'unknown') | upper %}
{% set is_open = status_raw in ('OPEN', 'FAIL', 'NON-COMPLIANT') %}
{% set sev = rule.get('severity', 'info') | lower %}
{% set cat_label = 'CAT I' if sev in ['high', 'critical'] else 'CAT II' if sev in ['medium', 'warning'] else 'CAT III' %}
<tr>
    <td class="col-id">{{ rule.get('rule_id', '') }}</td>
    <td>
        {% if status_raw in ('PASS', 'OK', 'COMPLIANT') %}<span class="sv-ok">{{ status_raw }}</span>
        {% elif status_raw == 'N/A' %}<span class="sv-info">N/A</span>
        {% elif is_open %}<span class="sv-critical">OPEN</span>
        {% else %}<span class="sv-warning">{{ status_raw }}</span>{% endif %}
    </td>
    <td>
        <span class="{{ 'sv-critical' if sev in ['high', 'critical'] else 'sv-warning' if sev in ['medium', 'warning'] else 'sv-info' }}">{{ cat_label }}</span>
    </td>
    <td>
        <div class="finding-title">{{ rule.get('title', 'No Title Provided') }}</div>
        {% if is_open %}
        {% set detail_desc = rule_detail.get('description', '') %}
        {% if rule.get('message') and rule.get('message') != rule.get('title') and rule.get('message') != detail_desc %}
        <div class="finding-message">{{ rule.get('message', '') }}</div>
        {% endif %}
        <details class="finding-details">
            <summary class="toggle-btn">View Technical Details</summary>
            <div class="details-box">
                {% if detail_desc or rule.get('message') %}
                <strong>DESCRIPTION / DISCUSSION:</strong>
                <div class="details-description">{{ detail_desc or rule.get('message', '') }}</div>
                {% endif %}
                {% if rule_detail.get('checktext') %}<strong>CHECK CONTENT:</strong><pre>{{ rule_detail.checktext }}</pre>{% endif %}
                {% if rule_detail.get('fixtext') %}<strong>REMEDIATION / FIX:</strong><pre>{{ rule_detail.fixtext }}</pre>{% endif %}
            </div>
        </details>
        {% endif %}
    </td>
</tr>
{% endmacro %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% set view = generic_node_view | default({}) %}
    {% set meta = view.get('meta', {}) %}
    {% set nav = view.get('nav', {}) %}
    {% set health = view.get('health', 'UNKNOWN') %}
    {% set summary = view.get('summary', {}) %}
    {% set alerts = view.get('alerts', []) %}
    {% set widgets = view.get('widgets', []) %}
    {% set crit = summary.get('critical_count', 0) %}
    {% set warn = summary.get('warning_count', 0) %}
    <title>{{ meta.get('display_name', 'Report') }} — Node Report — {{ meta.get('host', 'host') }}</title>
    <style>{{ _minified_css }}</style>
</head>
<body>
<div class="page-wrap">

    {% from '_breadcrumb_bar.html.j2' import breadcrumb_bar %}
    {% from '_alert_detail.html.j2' import alert_detail_row %}
    {{ breadcrumb_bar(nav.get('breadcrumbs', [])) }}

    {% if nav.get('sibling_reports') and nav.sibling_reports | length > 1 %}
    <div class="schema-tabs">
        {% for sr in nav.sibling_reports %}
        <a href="{{ sr.url }}" class="schema-tab{{ ' active' if sr.active else '' }}">{{ sr.label }}</a>
        {% endfor %}
    </div>
    {% endif %}

    <div class="page-header">
        <div>
            <h1>{{ meta.get('display_name', 'Report') }} &mdash; <code>{{ meta.get('host', 'host') }}</code></h1>
            <span class="page-subtitle">Platform: {{ meta.get('platform', '') | upper }}</span>
        </div>
        <div class="right">
            {% if health == 'OK' %}<span class="health-ok">OK</span>
            {% elif health == 'WARNING' %}<span class="health-warn">WARNING</span>
            {% elif health == 'CRITICAL' %}<span class="health-crit">CRITICAL</span>
            {% else %}<span class="health-unk">{{ health }}</span>{% endif %}
            <br>{{ meta.get('report_date', report_date | default('')) }}
        </div>
    </div>

    <div class="toc">
        <div class="toc-left">
            {% for widget in widgets %}
            <a href="#{{ widget.id }}">{{ widget.title }}</a>
            {% endfor %}
        </div>
    </div>

    <div class="widget-grid-container">
    {% for widget in widgets %}
        {% set w_width = widget.get('layout', {}).get('width', 'full') %}
        {% set flex_basis = '100%' %}
        {% if w_width == 'half' %}{% set flex_basis = 'calc(50% - 7px)' %}
        {% elif w_width == 'third' %}{% set flex_basis = 'calc(33.333% - 9.33px)' %}
        {% elif w_width == 'quarter' %}{% set flex_basis = 'calc(25% - 10.5px)' %}
        {% endif %}

        <div class="widget {{ 'widget-alert' if widget.type == 'alert_panel' else '' }}" id="{{ widget.id }}" style="flex: 1 1 {{ flex_basis }}; min-width: 300px; margin-bottom: 0;">
            <div class="widget-titlebar">
                {% if widget.type == 'alert_panel' %}
                <span class="widget-title">Active Alerts &mdash; {{ summary.get('total', 0) }}{% if crit > 0 %} ({{ crit }} CRITICAL{% if warn > 0 %}, {{ warn }} WARNING{% endif %}){% endif %}</span>
                {% else %}
                <span class="widget-title">{{ widget.title }}</span>
                {% endif %}
                <button class="widget-toggle" aria-expanded="true" aria-label="Collapse {{ widget.title }}"></button>
            </div>

            {# ── Non-table widget types ─────────────────────────────────────── #}

            {% if widget.type == 'progress_bar' %}
            <div class="widget-body" style="padding: 16px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 12px; font-weight: 600;">
                    <span>{{ widget.label }}</span>
                    <span>{{ widget.percent }}%</span>
                </div>
                <div style="background: var(--line); border-radius: 4px; height: 8px; overflow: hidden;">
                    <div style="width: {{ widget.percent }}%; height: 100%; background: var(--{{ widget.color|default('brand') }}); border-radius: 4px; transition: width 0.3s ease;"></div>
                </div>
            </div>

            {% elif widget.type == 'markdown' %}
            <div class="widget-body details-description" style="margin-bottom: 0; border: 1px solid var(--line); border-top: none; border-radius: 0 0 10px 10px;">
                {{ widget.content }}
            </div>

            {% elif widget.type == 'stat_cards' %}
            <div class="widget-body widget-body-padded">
            <div class="stat-cards-row">
                {% for card in widget.get('cards', []) %}
                <div class="stat-card stat-card-{{ card.color | default('blue') }}">
                    <div class="stat-card-value">{{ card.value }}</div>
                    <div class="stat-card-label">{{ card.label }}</div>
                </div>
                {% endfor %}
            </div>
            </div>

            {% elif widget.type == 'bar_chart' %}
            <div class="widget-body widget-body-padded">
            {% if widget.get('bars', []) %}
            <div class="bar-chart">
                {% for bar in widget.bars %}
                <div class="bar-chart-row">
                    <span class="bar-chart-label">{{ bar.label }}</span>
                    <div class="bar-chart-track">
                        <div class="bar-chart-fill bar-chart-{{ bar.color | default('blue') }}" style="width: {{ bar.width_pct }}%;"></div>
                    </div>
                    <span class="bar-chart-value">{{ bar.value | round(1) }}%</span>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="no-data">No data.</div>
            {% endif %}
            </div>

            {% elif widget.type == 'list' %}
            <div class="widget-body widget-body-padded">
            {% if widget.get('items', []) %}
                {% if widget.style == 'comma' %}
                <div class="list-widget-comma">{{ widget.items | join(', ') }}</div>
                {% elif widget.style == 'numbered' %}
                <ol class="list-widget">
                    {% for item in widget.items %}
                    <li>{{ item }}</li>
                    {% endfor %}
                </ol>
                {% else %}
                <ul class="list-widget">
                    {% for item in widget.items %}
                    <li>{{ item }}</li>
                    {% endfor %}
                </ul>
                {% endif %}
            {% else %}
            <div class="no-data">{{ widget.empty_text | default('None') }}</div>
            {% endif %}
            </div>

            {# ── STIG summary (two side-by-side KV tables + optional report link) #}

            {% elif widget.type == 'stig_summary' %}
            {% set by_status = widget.get('by_status', {}) %}
            {% set by_sev = widget.get('by_severity', {}) %}
            {% set not_reviewed = by_status.get('not_reviewed', 0) + by_status.get('unknown', 0) %}
            <div class="widget-body widget-subgroup">
                <div class="widget-grid">
                    <div class="widget">
                        <div class="widget-titlebar"><span class="widget-title">By Status</span></div>
                        <div class="widget-body widget-table-view">
                            <table class="kv"><tbody>
                                <tr><td class="kv-label-wide subtle-text">Total</td><td><strong>{{ widget.get('total', 0) }}</strong></td></tr>
                                <tr><td class="subtle-text">Passed</td><td><span class="sv-ok">{{ by_status.get('pass', 0) }}</span></td></tr>
                                <tr><td class="subtle-text">Open</td><td><span class="{{ 'sv-critical' if by_status.get('open', 0) > 0 else 'sv-ok' }}">{{ by_status.get('open', 0) }}</span></td></tr>
                                <tr><td class="subtle-text">N/A</td><td><span class="sv-info">{{ by_status.get('na', 0) }}</span></td></tr>
                                {% if not_reviewed > 0 %}
                                <tr><td class="subtle-text">Not Reviewed</td><td><span class="sv-warning">{{ not_reviewed }}</span></td></tr>
                                {% endif %}
                            </tbody></table>
                        </div>
                    </div>
                    <div class="widget">
                        <div class="widget-titlebar"><span class="widget-title">By Severity</span></div>
                        <div class="widget-body widget-table-view">
                            <table class="kv"><tbody>
                                <tr><td class="kv-label-wide subtle-text">CAT I</td><td><span class="{{ 'sv-critical' if by_sev.get('critical', 0) > 0 else 'sv-ok' }}">{{ by_sev.get('critical', 0) }}</span></td></tr>
                                <tr><td class="subtle-text">CAT II</td><td><span class="{{ 'sv-warning' if by_sev.get('warning', 0) > 0 else 'sv-ok' }}">{{ by_sev.get('warning', 0) }}</span></td></tr>
                                <tr><td class="subtle-text">CAT III</td><td><span class="sv-info">{{ by_sev.get('info', 0) }}</span></td></tr>
                            </tbody></table>
                        </div>
                    </div>
                </div>
                {% if widget.get('stig_report_url') %}
                <div class="widget-body" style="padding: 8px 14px; border-top: 1px solid var(--line);">
                    <a href="{{ widget.stig_report_url }}" class="link-strong">View full STIG report &rsaquo;</a>
                </div>
                {% endif %}
            </div>

            {# ── STIG findings table ───────────────────────────────────────── #}

            {% elif widget.type == 'stig_findings' %}
            <div class="widget-body widget-table-view">
            {% set findings = widget.get('findings', []) %}
            {% if findings %}
            <table>
                <thead>
                    <tr>
                        <th class="col-id sortable">Rule ID</th>
                        <th class="col-status sortable">Status</th>
                        <th class="col-sev sortable">Severity</th>
                        <th class="sortable">Details</th>
                    </tr>
                </thead>
                <tbody>
                {% for rule in findings %}
                    {{ render_finding_row(rule) }}
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No findings recorded.</div>
            {% endif %}
            </div>

            {# ── Table-view widget types (alert_panel, key_value, table, grouped_table) #}

            {% else %}
            <div class="widget-body widget-table-view">

            {% if widget.type == 'alert_panel' %}
            {% if alerts %}
            <table>
                <thead>
                    <tr><th class="th-severity">Severity</th><th class="th-category">Category</th><th>Message</th></tr>
                </thead>
                <tbody>
                {% for alert in alerts %}
                    {% set has_items = alert.get('affected_items', []) | length > 0 %}
                    <tr class="{{ 'alert-crit' if alert.severity == 'CRITICAL' else 'alert-warn' if alert.severity == 'WARNING' else '' }} {{ 'alert-expandable' if has_items else '' }}" {% if has_items %}data-alert-detail="alert-detail-{{ loop.index }}"{% endif %}>
                        <td class="{{ 'sv-critical' if alert.severity == 'CRITICAL' else 'sv-warning' if alert.severity == 'WARNING' else 'sv-info' }} nowrap">{{ alert.severity }}</td>
                        <td class="nowrap subtle-text strong-text alert-category">{{ alert.get('category', '') }}</td>
                        <td>
                            {{ alert.get('message', '') }}
                            {% if has_items %}<span class="alert-expand-hint">({{ alert.affected_items | length }} item{{ 's' if alert.affected_items | length != 1 else '' }})</span>{% endif %}
                            {% if alert.get('detail') %}
                            <div class="alert-details">
                                {% for dk, dv in alert.detail.items() %}
                                <span><strong>{{ dk }}:</strong> {{ dv }}</span>
                                {% endfor %}
                            </div>
                            {% endif %}
                        </td>
                    </tr>
                    {% if has_items %}
                    {{ alert_detail_row(alert, 'alert-detail-' ~ loop.index) }}
                    {% endif %}
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No active alerts.</div>
            {% endif %}

            {% elif widget.type == 'key_value' %}
            {% if widget.get('rows', []) %}
            <table class="kv">
                <tbody>
                {% for row in widget.rows %}
                    <tr><td>{{ row.label }}</td><td>{% if row.badge %}{{ render_badge(row.value) }}{% else %}{{ row.value }}{% endif %}</td></tr>
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No data.</div>
            {% endif %}

            {% elif widget.type == 'table' %}
            {% if widget.get('rows', []) %}
            <table>
                <thead>
                    <tr>
                    {% for col in widget.get('columns', []) %}
                        <th class="sortable">{{ col.label }}</th>
                    {% endfor %}
                    </tr>
                </thead>
                <tbody>
                {% for row in widget.rows %}
                    <tr class="row-interactive">
                    {% for cell in row %}
                        <td class="{{ cell.css_class | default('') }}">
                        {% if cell.link %}<a href="{{ cell.link }}" class="link-strong">{% endif %}
                        {% if cell.badge %}
                            {{ render_badge(cell.value) }}
                        {% else %}
                            {{ cell.value }}
                        {% endif %}
                        {% if cell.link %}</a>{% endif %}
                        </td>
                    {% endfor %}
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No rows.</div>
            {% endif %}

            {% elif widget.type == 'grouped_table' %}
            {% if widget.get('groups', {}) %}
            <table>
                <thead>
                    <tr>
                    {% for col in widget.get('columns', []) %}
                        <th class="sortable">{{ col.label }}</th>
                    {% endfor %}
                    </tr>
                </thead>
                <tbody>
                {% for group_name, group_rows in widget.groups.items() %}
                    {% set grp_id = "grp-" ~ widget.id ~ "-" ~ loop.index %}
                    <tr class="group-hdr" data-group="{{ grp_id }}">
                        <td colspan="{{ widget.columns | length }}">
                            <span class="group-toggle"></span>
                            <strong>{{ group_name }}</strong>
                            <span class="subtle-text">({{ group_rows | length }})</span>
                        </td>
                    </tr>
                    {% for row in group_rows %}
                    <tr class="group-row row-interactive" data-group="{{ grp_id }}">
                    {% for cell in row %}
                        <td class="{{ cell.css_class | default('') }}">
                        {% if cell.link %}<a href="{{ cell.link }}" class="link-strong">{% endif %}
                        {% if cell.badge %}
                            {{ render_badge(cell.value) }}
                        {% else %}
                            {{ cell.value }}
                        {% endif %}
                        {% if cell.link %}</a>{% endif %}
                        </td>
                    {% endfor %}
                    </tr>
                    {% endfor %}
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="no-data">No rows.</div>
            {% endif %}

            {% endif %}
            </div>
            {% endif %}
        </div>
    {% endfor %}
    </div>

</div>
<script>{{ _minified_js }}</script>
</body>
</html>
